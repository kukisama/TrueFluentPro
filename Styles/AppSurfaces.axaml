<Styles xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:icons="https://github.com/projektanker/icons.avalonia">
    <Style Selector="Border.app-card">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMd}"/>
        <Setter Property="BoxShadow" Value="0 8 24 0 #120F172A"/>
    </Style>

    <Style Selector="Border.sub-card">
        <Setter Property="Background" Value="{DynamicResource SubCardBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SubCardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSm}"/>
    </Style>

    <Style Selector="Border.nav-surface">
        <Setter Property="Background" Value="{DynamicResource NavPanelBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
    </Style>

    <Style Selector="Border.toolbar-surface">
        <Setter Property="Background" Value="{DynamicResource NavPanelBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
    </Style>

    <Style Selector="TextBlock.secondary-nav-title">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="TextBlock.secondary-nav-note">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}"/>
    </Style>

    <Style Selector="Grid.secondary-nav-header">
        <Setter Property="MinHeight" Value="76"/>
    </Style>

    <Style Selector="Grid.secondary-nav-header-title-row">
        <Setter Property="MinHeight" Value="24"/>
    </Style>

    <Style Selector="Grid.secondary-nav-header-action-row">
        <Setter Property="MinHeight" Value="36"/>
    </Style>

    <Style Selector="Button.secondary-nav-primary">
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
    </Style>

    <Style Selector="Button.secondary-nav-compact">
        <Setter Property="Height" Value="32"/>
        <Setter Property="MinWidth" Value="32"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
    </Style>

    <Style Selector="Button.secondary-nav-ghost">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
    </Style>

    <Style Selector="Button.secondary-nav-ghost:pointerover">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
    </Style>

    <Style Selector="Button.secondary-nav-ghost:pressed">
        <Setter Property="Background" Value="{DynamicResource SubCardBackgroundBrush}"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem">
        <Setter Property="Margin" Value="0,2,0,2"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem /template/ ContentPresenter">
        <Setter Property="Padding" Value="18,9,12,9"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="ClipToBounds" Value="False"/>
    </Style>

    <Style Selector="Grid.sidebar-nav-item-content">
        <Setter Property="Margin" Value="10,0,0,0"/>
        <Setter Property="MinHeight" Value="22"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.sidebar-nav-label">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem icons|Icon">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem:selected TextBlock">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem:selected icons|Icon">
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem:pointerover TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="Border.sidebar-nav-badge">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="Padding" Value="8,2"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.sidebar-nav-badge-text">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Ellipse.sidebar-nav-dot">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Height" Value="8"/>
        <Setter Property="Fill" Value="{DynamicResource IndicatorGreenBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="6,0,2,0"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem:selected Border.sidebar-nav-badge">
        <Setter Property="Background" Value="#2AFFFFFF"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem:selected TextBlock.sidebar-nav-badge-text">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem:selected Ellipse.sidebar-nav-dot">
        <Setter Property="Fill" Value="#E6FFFFFF"/>
    </Style>
</Styles>
