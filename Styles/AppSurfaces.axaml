<Styles xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:icons="https://github.com/projektanker/icons.avalonia">
    <Style Selector="Border.app-card">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BoxShadow" Value="0 8 24 0 #120F172A"/>
    </Style>

    <Style Selector="Border.sub-card">
        <Setter Property="Background" Value="{DynamicResource SubCardBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SubCardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Border.nav-surface">
        <Setter Property="Background" Value="{DynamicResource NavPanelBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
    </Style>

    <Style Selector="Border.toolbar-surface">
        <Setter Property="Background" Value="{DynamicResource NavPanelBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem">
        <Setter Property="Margin" Value="0,2,0,2"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem /template/ ContentPresenter">
        <Setter Property="Padding" Value="18,9,12,9"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="ClipToBounds" Value="False"/>
    </Style>

    <Style Selector="Grid.sidebar-nav-item-content">
        <Setter Property="Margin" Value="10,0,0,0"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem icons|Icon">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem:selected TextBlock">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem:selected icons|Icon">
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style Selector="ListBox.sidebar-nav-list > ListBoxItem:pointerover TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
</Styles>
