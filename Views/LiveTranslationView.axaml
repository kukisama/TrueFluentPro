<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:TrueFluentPro.ViewModels"
             xmlns:models="using:TrueFluentPro.Models"
             xmlns:controls="using:TrueFluentPro.Controls"
             xmlns:icons="https://github.com/projektanker/icons.avalonia"
             xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="TrueFluentPro.Views.LiveTranslationView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">

    <UserControl.Resources>
        <controls:LevelToHeightConverter x:Key="LevelToHeight" MaxHeight="16"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="ToggleButton.audio-pill">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinWidth" Value="72" />
        </Style>
        <Style Selector="ToggleButton.audio-pill:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        </Style>
        <Style Selector="ToggleButton.audio-pill:checked">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryDarkBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <!-- 3.4 SegmentedControl 显示模式样式 -->
        <Style Selector="ToggleButton.segment-btn">
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinWidth" Value="48" />
        </Style>
        <Style Selector="ToggleButton.segment-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        </Style>
        <Style Selector="ToggleButton.segment-btn:checked">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryDarkBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <!-- 可展开提示词输入框：默认单行紧凑，聚焦后展开多行 -->
        <Style Selector="TextBox.expandable-prompt">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="MaxHeight" Value="28"/>
            <Setter Property="AcceptsReturn" Value="False"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>
        <Style Selector="TextBox.expandable-prompt:focus">
            <Setter Property="MaxHeight" Value="100"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto"
          Background="{DynamicResource PageBackgroundBrush}">
        <!-- 语音资源与输入选择区域（紧凑工具栏） -->
        <Border Grid.Row="0" Classes="toolbar-surface"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1"
            Padding="12,10" Margin="0,0,0,10" MinHeight="56">
            <WrapPanel Orientation="Horizontal" ItemHeight="36"
                   VerticalAlignment="Center">
            <!-- 语音资源选择 -->
            <TextBlock Text="语音资源:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Name="SubscriptionComboBox" MinWidth="150" 
                  ItemsSource="{Binding ConfigVM.SpeechResourceNames}" 
                  SelectedIndex="{Binding ConfigVM.ActiveSpeechResourceIndex, Mode=TwoWay}"
                          IsEnabled="{Binding ConfigVM.IsConfigurationEnabled}"
                  Margin="0,0,8,0"
                  AutomationProperties.Name="语音资源选择"
                  ToolTip.Tip="选择要使用的语音资源"/>
                <Ellipse Width="12" Height="12" StrokeThickness="2"
                         VerticalAlignment="Center"
                         Fill="{Binding ConfigVM.SubscriptionLampFill}"
                         Stroke="{Binding ConfigVM.SubscriptionLampStroke}"
                         Opacity="{Binding ConfigVM.SubscriptionLampOpacity}"
                 Margin="0,0,8,0"
                         ToolTip.Tip="{Binding ConfigVM.SubscriptionValidationStatusMessage}"/>

                <!-- 语言对 -->
            <TextBlock Text="源语言:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Name="SourceLanguageComboBox" MinWidth="100"
                          IsEnabled="{Binding ConfigVM.IsConfigurationEnabled}"
                          AutomationProperties.Name="源语言"
                  Margin="0,0,4,0"
                          SelectedIndex="{Binding ConfigVM.SourceLanguageIndex}">
                <ComboBoxItem Tag="auto" Content="自动识别"/>
                <ComboBoxItem Tag="en-US" Content="英语"/>
                <ComboBoxItem Tag="zh-CN" Content="中文"/>
                <ComboBoxItem Tag="ja-JP" Content="日语"/>
                <ComboBoxItem Tag="ko-KR" Content="韩语"/>
                <ComboBoxItem Tag="fr-FR" Content="法语"/>
                <ComboBoxItem Tag="de-DE" Content="德语"/>
                <ComboBoxItem Tag="es-ES" Content="西班牙语"/>
                </ComboBox>
                    <TextBlock Text="→" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,4,0"/>
                <ComboBox Name="TargetLanguageComboBox" MinWidth="100"
                      IsEnabled="{Binding ConfigVM.IsConfigurationEnabled}"
                      AutomationProperties.Name="目标语言"
                        Margin="0,0,8,0"
                      SelectedIndex="{Binding ConfigVM.TargetLanguageIndex}">
                <ComboBoxItem Tag="en" Content="英语"/>
                <ComboBoxItem Tag="zh-Hans" Content="中文"/>
                <ComboBoxItem Tag="ja" Content="日语"/>
                <ComboBoxItem Tag="ko" Content="韩语"/>
                <ComboBoxItem Tag="fr" Content="法语"/>
                <ComboBoxItem Tag="de" Content="德语"/>
                <ComboBoxItem Tag="es" Content="西班牙语"/>
                </ComboBox>

                <!-- 开始/停止翻译 -->
                <Button Classes="pressable"
                    Content="{Binding TranslationToggleButtonText}"
                    Command="{Binding ToggleTranslationCommand}"
                    Background="{Binding TranslationToggleButtonBackground}"
                    Foreground="{Binding TranslationToggleButtonForeground}"
                    Padding="10,5" Margin="0,0,8,0"
                    AutomationProperties.Name="开始/停止翻译 (F5/F6)"
                    ToolTip.Tip="F5 开始翻译, F6 停止翻译"/>

            <!-- 3.3 翻译状态脉冲动画：录音指示器 -->
                 <Ellipse Name="RecordingIndicator" Width="10" Height="10"
                        Fill="Red" VerticalAlignment="Center" Margin="6,0,0,0"
                        IsVisible="{Binding IsTranslating}">
                <Ellipse.Styles>
                    <Style Selector="Ellipse#RecordingIndicator">
                        <Style.Animations>
                            <Animation Duration="0:0:1.2" IterationCount="INFINITE">
                                <KeyFrame Cue="0%">
                                    <Setter Property="Opacity" Value="1.0"/>
                                </KeyFrame>
                                <KeyFrame Cue="50%">
                                    <Setter Property="Opacity" Value="0.3"/>
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="Opacity" Value="1.0"/>
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </Ellipse.Styles>
                </Ellipse>

            <!-- 音频设备 Flyout -->
                <Button Content="🎧 音频设备" Padding="8,5" Margin="8,0,8,0"
                    ToolTip.Tip="配置麦克风、系统回环和录制来源">
                <Button.Flyout>
                    <Flyout Placement="BottomEdgeAlignedLeft">
                        <StackPanel Spacing="10" Width="360">
                            <StackPanel Spacing="4">
                                <TextBlock Text="麦克风" FontWeight="SemiBold" FontSize="12"/>
                                <ComboBox Name="InputDeviceComboBox"
                                          ItemsSource="{Binding AudioDevices.AudioDevicesList}"
                                          SelectedItem="{Binding AudioDevices.SelectedAudioDevice, Mode=TwoWay}"
                                          IsEnabled="{Binding AudioDevices.IsInputDeviceUiEnabled}"
                                          HorizontalAlignment="Stretch"
                                          ToolTip.Tip="选择麦克风设备（选'无'表示不采集麦克风）"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="系统回环" FontWeight="SemiBold" FontSize="12"/>
                                <ComboBox Name="OutputDeviceComboBox"
                                          ItemsSource="{Binding AudioDevices.OutputDevicesList}"
                                          SelectedItem="{Binding AudioDevices.SelectedOutputDevice, Mode=TwoWay}"
                                          IsEnabled="{Binding AudioDevices.IsOutputDeviceUiEnabled}"
                                          HorizontalAlignment="Stretch"
                                          ToolTip.Tip="选择系统回环设备（选'无'表示不采集系统回环）"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="录制来源" FontWeight="SemiBold" FontSize="12"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ToggleButton Content="仅环回"
                                                  Classes="audio-pill"
                                                  IsChecked="{Binding AudioDevices.IsRecordingLoopbackOnly, Mode=TwoWay}"/>
                                    <ToggleButton Content="环回+麦克风"
                                                  Classes="audio-pill"
                                                  IsChecked="{Binding AudioDevices.IsRecordingLoopbackMix, Mode=TwoWay}"/>
                                    <ToggleButton Content="仅麦克风"
                                                  Classes="audio-pill"
                                                  IsChecked="{Binding AudioDevices.IsRecordingMicOnly, Mode=TwoWay}"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Content="刷新设备" HorizontalAlignment="Stretch"
                                    Command="{Binding AudioDevices.RefreshAudioDevicesCommand}"
                                    IsEnabled="{Binding AudioDevices.IsAudioDeviceRefreshEnabled}"
                                    ToolTip.Tip="刷新音频设备列表"/>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
                </Button>

                <Border Width="84" Height="22"
                    Background="Transparent" BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1"
                    CornerRadius="6" VerticalAlignment="Center"
                    Margin="0,0,8,0"
                    AutomationProperties.Name="音频活动电平指示器"
                    ToolTip.Tip="音频活动电平">
                <Grid>
                    <Border Height="1" Background="{DynamicResource DividerBrush}" VerticalAlignment="Center"/>
                    <ItemsControl ItemsSource="{Binding AudioDevices.AudioLevelHistory}" VerticalAlignment="Bottom" Margin="4,3">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="2"
                                        Height="{Binding Converter={StaticResource LevelToHeight}}"
                                        Background="{DynamicResource SuccessBrush}"
                                        Opacity="0.85"
                                        VerticalAlignment="Bottom"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
                </Border>
            </WrapPanel>
        </Border>

        <!-- 中间翻译内容区域 -->
        <Grid Grid.Row="1" Margin="12,0,12,0" ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="420"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="2*" MinWidth="300"/>
            </Grid.ColumnDefinitions>
            <!-- 左侧实时翻译区域 -->
            <Border Grid.Column="0" Classes="app-card" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <Grid RowDefinitions="Auto,*,Auto">
                    <DockPanel Grid.Row="0" Margin="5">
                        <TextBlock Text="实时翻译" FontWeight="Bold" DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Right">
                            <ToggleButton Content="原文" Classes="segment-btn"
                                          IsChecked="{Binding IsOriginalView}"
                                          AutomationProperties.Name="显示原文"/>
                            <ToggleButton Content="译文" Classes="segment-btn"
                                          IsChecked="{Binding IsTranslatedView}"
                                          AutomationProperties.Name="显示译文"/>
                            <ToggleButton Content="双语" Classes="segment-btn"
                                          IsChecked="{Binding IsBilingualView}"
                                          AutomationProperties.Name="显示双语对照"/>
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="1" Margin="5">
                        <Border Classes="sub-card" BorderBrush="{DynamicResource SubCardBorderBrush}" BorderThickness="1" CornerRadius="6" IsVisible="{Binding IsSingleView}">
                            <controls:ConfigurableTextEditor x:Name="UnifiedEditor"
                                                             Text="{Binding DisplayedText, Mode=TwoWay}"
                                                             Placeholder="{Binding DisplayPlaceholder}"
                                                             EditorType="Advanced"/>
                        </Border>
                        <Grid RowDefinitions="*,6,*" IsVisible="{Binding IsBilingualView}">
                            <Border Grid.Row="0" Classes="sub-card" BorderBrush="{DynamicResource SubCardBorderBrush}" BorderThickness="1" CornerRadius="6">
                                <controls:ConfigurableTextEditor Text="{Binding CurrentOriginal, Mode=TwoWay}"
                                                                 Placeholder="原文将在这里显示..."
                                                                 EditorType="Advanced"/>
                            </Border>
                            <Border Grid.Row="2" Classes="sub-card" BorderBrush="{DynamicResource SubCardBorderBrush}" BorderThickness="1" CornerRadius="6">
                                <controls:ConfigurableTextEditor Text="{Binding CurrentTranslated, Mode=TwoWay}"
                                                                 Placeholder="译文将在这里显示..."
                                                                 EditorType="Advanced"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="10"
                          Background="Transparent"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ShowsPreview="True"/>
            
            <!-- 右侧历史/洞察区域 -->
            <Border Grid.Column="2" Classes="app-card" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <TabControl SelectedIndex="{Binding LiveSidePanelTabIndex, Mode=TwoWay}">
                    <TabItem Header="历史记录">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Row="0" Text="历史记录" FontWeight="Bold" Margin="5"/>
                            <ListBox Grid.Row="1" ItemsSource="{Binding History}" Margin="5">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="models:TranslationItem">
                                        <Border Classes="sub-card" Margin="0,4" BorderBrush="{DynamicResource SubCardBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="6">
                                            <Expander>
                                                <Expander.Header>
                                                    <StackPanel Spacing="2">
                                                        <DockPanel>
                                                            <TextBlock Text="{Binding Timestamp, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}" FontWeight="Bold" DockPanel.Dock="Left"/>
                                                            <TextBlock Text="{Binding TranslatedText}" Foreground="{DynamicResource PrimaryBrush}"
                                                                       TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                                                        </DockPanel>
                                                        <TextBlock Text="{Binding OriginalText}" Foreground="{DynamicResource TextSubtleBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Expander.Header>
                                                <StackPanel Spacing="6" Margin="0,6,0,0">
                                                    <TextBlock Text="原文" FontSize="10" Foreground="{DynamicResource TextSubtleBrush}"/>
                                                    <TextBlock Text="{Binding OriginalText}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="译文" FontSize="10" Foreground="{DynamicResource TextSubtleBrush}"/>
                                                    <TextBlock Text="{Binding TranslatedText}" TextWrapping="Wrap" Foreground="{DynamicResource PrimaryBrush}"/>
                                                </StackPanel>
                                            </Expander>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>
                    <TabItem Header="洞察">
                        <ContentControl Content="{Binding LiveInsightTabContent}">
                            <ContentControl.DataTemplates>
                                <DataTemplate DataType="vm:MainWindowViewModel">
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
                                        <!-- AI 状态 -->
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4" Spacing="10">
                                            <TextBlock Text="未配置 AI 服务" Foreground="{DynamicResource WarningBrush}"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       IsVisible="{Binding !AiInsight.IsAiConfigured}"/>
                                            <TextBlock Text="AI 服务已就绪" Foreground="{DynamicResource SuccessBrush}"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       IsVisible="{Binding AiInsight.IsAiConfigured}"/>
                                        </StackPanel>

                                        <!-- 预设分析模板按钮 -->
                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding AiInsight.InsightPresetButtons}" Margin="8,4">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:CompileBindings="False">
                                                    <Button Content="{Binding Name}" Margin="0,0,6,6" Padding="8,4"
                                                            Command="{Binding $parent[ItemsControl].DataContext.AiInsight.SendPresetInsightCommand}"
                                                            CommandParameter="{Binding Prompt}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- 自定义输入框 + 发送/停止 -->
                                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="8,4">
                                            <TextBox Grid.Column="0" Text="{Binding AiInsight.InsightUserInput, Mode=TwoWay}"
                                                     Watermark="输入自定义分析问题..." Padding="6,4"
                                                     AcceptsReturn="False"/>
                                            <Button Grid.Column="1" Content="发送" Margin="6,0,0,0" Padding="12,4"
                                                    Command="{Binding AiInsight.SendInsightCommand}"/>
                                            <Button Grid.Column="2" Content="停止" Margin="6,0,0,0" Padding="12,4"
                                                    Command="{Binding AiInsight.StopInsightCommand}"
                                                    IsVisible="{Binding AiInsight.IsInsightLoading}"/>
                                        </Grid>

                                        <!-- 自动循环洞察 -->
                                        <Border Grid.Row="3" Classes="sub-card" Margin="8,4" Padding="8,6"
                                                Background="{DynamicResource SubCardBackgroundBrush}" BorderBrush="{DynamicResource SubCardBorderBrush}"
                                                BorderThickness="1" CornerRadius="6">
                                            <Grid RowDefinitions="Auto,Auto">
                                                <WrapPanel Grid.Row="0" Orientation="Horizontal">
                                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,10,4">
                                                        <TextBlock Text="自动洞察:" FontSize="11" VerticalAlignment="Center"/>
                                                        <ComboBox MinWidth="100"
                                                                  SelectedIndex="{Binding AiInsight.AutoInsightModeIndex, Mode=TwoWay}"
                                                                  IsEnabled="{Binding !AiInsight.IsAutoInsightEnabled}"
                                                                  VerticalAlignment="Center">
                                                            <ComboBoxItem Content="定时循环"/>
                                                            <ComboBoxItem Content="新数据触发"/>
                                                        </ComboBox>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,10,4">
                                                        <TextBlock Text="间隔(秒):" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBox Text="{Binding AiInsight.AutoInsightIntervalSeconds, Mode=TwoWay}"
                                                                 Width="60" Padding="6,4" VerticalAlignment="Center"
                                                                 IsEnabled="{Binding !AiInsight.IsAutoInsightEnabled}"/>
                                                    </StackPanel>
                                                    <Button Content="{Binding AiInsight.AutoInsightToggleText}"
                                                            Command="{Binding AiInsight.ToggleAutoInsightCommand}"
                                                            Padding="10,4" Margin="0,0,0,4"
                                                            VerticalAlignment="Center"/>
                                                </WrapPanel>
                                                <TextBox Grid.Row="1" Classes="expandable-prompt"
                                                         Text="{Binding AiInsight.AutoInsightPrompt, Mode=TwoWay}"
                                                         Watermark="自动分析使用的提示词（点击展开编辑）..."
                                                         Padding="6,4" Margin="0,2,0,0"
                                                         IsEnabled="{Binding !AiInsight.IsAutoInsightEnabled}"/>
                                            </Grid>
                                        </Border>

                                        <!-- Markdown 渲染结果区 -->
                                        <Border Grid.Row="4" Classes="sub-card" Margin="8,4" BorderBrush="{DynamicResource SubCardBorderBrush}"
                                                BorderThickness="1" CornerRadius="6">
                                            <Grid>
                                                <ScrollViewer IsVisible="{Binding !AiInsight.IsInsightEmpty}">
                                                    <md:MarkdownScrollViewer Markdown="{Binding AiInsight.InsightMarkdown}"/>
                                                </ScrollViewer>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                            IsVisible="{Binding AiInsight.IsInsightLoading}">
                                                    <TextBlock Text="AI 正在分析..." Foreground="{DynamicResource TextSubtleBrush}"
                                                               FontSize="12" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="选择预设模板或输入问题开始分析"
                                                           Foreground="{DynamicResource TextSubtleBrush}" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           IsVisible="{Binding AiInsight.IsInsightEmpty}"/>
                                            </Grid>
                                        </Border>

                                        <!-- 清除按钮 -->
                                        <StackPanel Grid.Row="5" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" Margin="8,4,8,8">
                                            <Button Content="清除结果" Padding="8,4"
                                                    Command="{Binding AiInsight.ClearInsightCommand}"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ContentControl.DataTemplates>
                        </ContentControl>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    
        <!-- 底部操作栏 -->
        <Border Grid.Row="2" Classes="toolbar-surface" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="10,6" Margin="0,8,0,0">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto">
                <!-- 清空历史 -->
                <Button Grid.Column="0" Command="{Binding ClearHistoryCommand}" 
                        Padding="10,5" Margin="0,0,6,0"
                        AutomationProperties.Name="清空翻译历史">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <icons:Icon Value="fa-solid fa-trash-can" FontSize="12"/>
                        <TextBlock Text="清空历史" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- 查看历史记录 -->
                <Button Grid.Column="1" Command="{Binding OpenHistoryFolderCommand}" 
                        Padding="10,5" Margin="0,0,6,0"
                        AutomationProperties.Name="打开历史记录文件夹"
                        ToolTip.Tip="打开本地历史记录文件夹，查看保存的翻译文件">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <icons:Icon Value="fa-solid fa-folder-open" FontSize="12"/>
                        <TextBlock Text="查看历史记录" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- 浮动字幕 -->
                <Button Grid.Column="2" Command="{Binding ShowFloatingSubtitlesCommand}" 
                        Padding="10,5" Margin="0,0,6,0"
                        Background="{Binding FloatingSubtitleButtonBackground}"
                        Foreground="{Binding FloatingSubtitleButtonForeground}"
                        AutomationProperties.Name="切换浮动字幕窗口"
                        ToolTip.Tip="使用可拖动的透明字幕框提供服务">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <icons:Icon Value="fa-solid fa-closed-captioning" FontSize="12"/>
                        <TextBlock Text="浮动字幕" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- 浮动洞察 -->
                <Button Grid.Column="3" Command="{Binding ShowFloatingInsightCommand}" 
                        Padding="10,5" Margin="0,0,6,0"
                        Background="{Binding FloatingInsightButtonBackground}"
                        Foreground="{Binding FloatingInsightButtonForeground}"
                        AutomationProperties.Name="切换浮动洞察窗口"
                        ToolTip.Tip="弹出浮动洞察窗口，实时同步 AI 洞察结果">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <icons:Icon Value="fa-solid fa-brain" FontSize="12"/>
                        <TextBlock Text="浮动洞察" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- 状态信息（右侧） -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="{DynamicResource TextSubtleBrush}"
                               VerticalAlignment="Center" MaxWidth="400" TextTrimming="CharacterEllipsis"
                               AutomationProperties.Name="翻译状态信息"/>
                    <TextBlock Text="{Binding ConfigVM.SubscriptionValidationStatusMessage}" 
                               FontSize="10" Foreground="{DynamicResource TextSubtleBrush}" VerticalAlignment="Center"
                               AutomationProperties.Name="订阅验证状态"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>