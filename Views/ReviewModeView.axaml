<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:TrueFluentPro.ViewModels"
             xmlns:models="using:TrueFluentPro.Models"
             xmlns:controls="using:TrueFluentPro.Controls"
             xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="TrueFluentPro.Views.ReviewModeView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">

    <UserControl.Resources>
        <controls:ProgressToOffsetConverter x:Key="ProgressToOffset" Padding="6"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Slider#PlaybackSlider">
            <Setter Property="Height" Value="12" />
            <Setter Property="Background" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <!-- 右键仅弹菜单：抑制音频列表项的按下闪烁视觉态 -->
        <Style Selector="ListBox#AudioFileListBox > ListBoxItem:pressed">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Slider#PlaybackSlider /template/ Thumb">
            <Setter Property="Width" Value="9" />
            <Setter Property="Height" Value="9" />
            <Setter Property="CornerRadius" Value="4.5" />
            <Setter Property="MinWidth" Value="9" />
            <Setter Property="MinHeight" Value="9" />
            <Setter Property="MaxWidth" Value="9" />
            <Setter Property="MaxHeight" Value="9" />
            <Setter Property="Background" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Slider#PlaybackSlider /template/ Track">
            <Setter Property="Height" Value="3" />
        </Style>
        <!-- 3.7 拖放高亮样式 -->
        <Style Selector="Border#DropZone">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderMediumBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid Margin="12"
          Background="{DynamicResource PageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="292" MinWidth="240"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*" MinWidth="320"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="332" MinWidth="320"/>
        </Grid.ColumnDefinitions>
        <!-- 左侧文件与当前文件操作 -->
        <Border Grid.Column="0" Classes="app-card" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10"
            >
            <StackPanel Spacing="10">
                <!-- 3.7 文件拖放区 -->
                <Border Name="DropZone" Classes="sub-card"
                        BorderBrush="{DynamicResource BorderMediumBrush}"
                        BorderThickness="2"
                        CornerRadius="6"
                        Padding="12,8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        DragDrop.AllowDrop="True"
                        AutomationProperties.Name="拖放音频文件到此处导入">
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="📂 拖放音频文件到此处" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="支持 WAV / MP3 / FLAC / M4A" FontSize="9"
                                   Foreground="{DynamicResource TextPlaceholderBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <DockPanel>
                    <TextBlock Text="音频文件" FontSize="11" Foreground="{DynamicResource TextSubtleBrush}" DockPanel.Dock="Left"/>
                    <Button Content="刷新" Width="50" Padding="6,2" Command="{Binding FileLibrary.RefreshAudioLibraryCommand}"
                            HorizontalAlignment="Right" DockPanel.Dock="Right"
                            AutomationProperties.Name="刷新音频文件列表"/>
                </DockPanel>
                <ListBox Name="AudioFileListBox" Classes="sidebar-nav-list" Height="188"
                         ItemsSource="{Binding FileLibrary.AudioFiles}" SelectedItem="{Binding FileLibrary.SelectedAudioFile}"
                         Focusable="False"
                         AutomationProperties.Name="音频文件列表"
                         PointerReleased="AudioFileListBox_PointerReleased">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="models:MediaFileItem">
                            <StackPanel Spacing="3" Margin="0,2">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                    <Border Grid.Column="1"
                                            Padding="6,1"
                                            CornerRadius="999"
                                            Background="{DynamicResource SurfaceHoverBrush}"
                                            IsVisible="{Binding HasProcessingBadge}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentBlueBrush}" IsVisible="{Binding IsProcessingPending}"/>
                                            <Ellipse Width="6" Height="6" Fill="{DynamicResource WarningBrush}" IsVisible="{Binding IsProcessingRunning}"/>
                                            <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentBlueBrush}" IsVisible="{Binding IsProcessingPartial}"/>
                                            <Ellipse Width="6" Height="6" Fill="{DynamicResource SuccessBrush}" IsVisible="{Binding IsProcessingCompleted}"/>
                                            <Ellipse Width="6" Height="6" Fill="{DynamicResource ErrorBrush}" IsVisible="{Binding IsProcessingFailed}"/>
                                            <Ellipse Width="6" Height="6" Fill="{DynamicResource TextSubtleBrush}" IsVisible="{Binding IsProcessingRemoved}"/>
                                            <TextBlock Text="{Binding ProcessingBadgeText}" FontSize="10" Foreground="{DynamicResource TextSubtleBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding ProcessingDetailText}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextSubtleBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           IsVisible="{Binding HasProcessingBadge}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="字幕文件" FontSize="11" Foreground="{DynamicResource TextSubtleBrush}"/>
                <ListBox Classes="sidebar-nav-list" ItemsSource="{Binding FileLibrary.SubtitleFiles}" SelectedItem="{Binding FileLibrary.SelectedSubtitleFile}" Height="132"
                         AutomationProperties.Name="字幕文件列表">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="models:MediaFileItem">
                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Classes="sub-card" BorderBrush="{DynamicResource SubCardBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="当前文件操作" FontWeight="SemiBold"/>
                        <TextBlock Text="这里聚焦单文件工作流：切字幕、生成当前文件复盘；多文件后台生产统一进入批处理中心。"
                                   TextWrapping="Wrap"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextSubtleBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Content="生成 Speech 字幕"
                                    Padding="8,4"
                                    Command="{Binding BatchProcessing.GenerateBatchSpeechSubtitleCommand}"/>
                            <Button Content="加入批处理中心"
                                    Padding="8,4"
                                    Command="{Binding BatchProcessing.EnqueueSubtitleReviewCommand}"
                                    CommandParameter="{Binding FileLibrary.SelectedAudioFile}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding BatchProcessing.SpeechSubtitleStatusMessage}"
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSubtleBrush}"/>
                        <TextBlock Text="{Binding BatchProcessing.SpeechSubtitleOptionStatusText}"
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSubtleBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- 左侧 GridSplitter -->
        <GridSplitter Grid.Column="1" Width="12" Background="Transparent"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  ResizeDirection="Columns"
                  ShowsPreview="True"/>

        <!-- 中部播放器与字幕 -->
        <Border Grid.Column="2" Classes="app-card" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
            <Grid RowDefinitions="Auto,Auto,*">
                <StackPanel Grid.Row="0" Spacing="6">
                    <TextBlock Text="音频播放" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="▶" Width="40" Height="32" FontSize="16" Command="{Binding Playback.PlayAudioCommand}"
                                IsEnabled="{Binding Playback.IsPlayEnabled}" IsVisible="{Binding Playback.IsPlayEnabled}"
                                AutomationProperties.Name="播放音频"/>
                        <Button Content="⏸" Width="40" Height="32" FontSize="16" Command="{Binding Playback.PauseAudioCommand}"
                                IsEnabled="{Binding Playback.IsPauseEnabled}" IsVisible="{Binding Playback.IsPauseEnabled}"
                                AutomationProperties.Name="暂停音频"/>
                        <TextBlock Text="{Binding Playback.PlaybackTimeText}" VerticalAlignment="Center" Foreground="{DynamicResource TextSubtleBrush}"/>
                    </StackPanel>
                </StackPanel>
                <Grid Grid.Row="1" RowDefinitions="Auto,Auto" Margin="0,6,0,6">
                    <TextBlock Grid.Row="0"
                               Text="{Binding Playback.PlaybackTimeText}"
                               FontSize="10"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,4"/>
                    <Slider Grid.Row="1" Name="PlaybackSlider" Minimum="0" Maximum="1"
                            Value="{Binding Playback.PlaybackProgress, Mode=TwoWay}"/>
                </Grid>
                <Border Grid.Row="2" Classes="sub-card" BorderBrush="{DynamicResource SubCardBorderBrush}" BorderThickness="1" CornerRadius="6">
                    <ListBox Name="SubtitleCueListBox" ItemsSource="{Binding FileLibrary.SubtitleCues}" SelectedItem="{Binding FileLibrary.SelectedSubtitleCue}" Margin="0" Padding="0"
                             Background="Transparent"
                             DoubleTapped="SubtitleCueListBox_DoubleTapped"
                             PointerReleased="SubtitleCueListBox_PointerReleased">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="models:SubtitleCue">
                                <StackPanel Margin="0,2">
                                    <TextBlock Text="{Binding RangeText}" FontSize="10" Foreground="{DynamicResource TextSubtleBrush}"/>
                                    <TextBlock Text="{Binding Text}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>
        </Border>

        <!-- 右侧 GridSplitter -->
        <GridSplitter Grid.Column="3" Width="12" Background="Transparent"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  ResizeDirection="Columns"
                  ShowsPreview="True"/>

        <!-- 右侧当前文件复盘洞察 -->
        <Border Grid.Column="4" Classes="app-card" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10"
            >
            <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="当前文件复盘" FontWeight="Bold"/>
                    <Ellipse Width="10" Height="10" StrokeThickness="2"
                             Fill="{Binding BatchProcessing.ReviewSummaryLampFill}"
                             Stroke="{Binding BatchProcessing.ReviewSummaryLampStroke}"
                             Opacity="{Binding ConfigVM.ReviewSummaryLampOpacity}"
                             VerticalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Row="1" Classes="sub-card" BorderBrush="{DynamicResource SubCardBorderBrush}" BorderThickness="1" CornerRadius="6" Margin="0,8,0,8">
                    <TabControl ItemsSource="{Binding BatchProcessing.ReviewSheets}"
                                SelectedItem="{Binding BatchProcessing.SelectedReviewSheet, Mode=TwoWay}">
                        <TabControl.ItemTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <Grid>
                                    <md:MarkdownScrollViewer IsVisible="{Binding !IsEmpty}"
                                                             Markdown="{Binding Markdown}">
                                        <md:MarkdownScrollViewer.Engine>
                                            <md:Markdown HyperlinkCommand="{Binding $parent[TabControl].DataContext.BatchProcessing.ReviewMarkdownLinkCommand}" />
                                        </md:MarkdownScrollViewer.Engine>
                                    </md:MarkdownScrollViewer>
                                    <TextBlock Text="选择当前文件与字幕后生成复盘内容"
                                               Foreground="{DynamicResource TextSubtleBrush}" FontSize="12"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               IsVisible="{Binding IsEmpty}"/>
                                </Grid>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </Border>
                <StackPanel Grid.Row="2" Orientation="Vertical" Spacing="6">
                    <TextBlock Text="{Binding BatchProcessing.ReviewSummaryStatusMessage}" FontSize="11" Foreground="{DynamicResource TextSubtleBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                        <Button Content="生成内容" Padding="8,4"
                                Command="{Binding BatchProcessing.GenerateReviewSummaryCommand}"/>
                        <Button Content="生成全部" Padding="8,4"
                            Command="{Binding BatchProcessing.GenerateAllReviewSheetsCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
