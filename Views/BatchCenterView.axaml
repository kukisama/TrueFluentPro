<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:TrueFluentPro.ViewModels"
             xmlns:models="using:TrueFluentPro.Models"
             xmlns:icons="https://github.com/projektanker/icons.avalonia"
             mc:Ignorable="d"
             d:DesignWidth="1280"
             d:DesignHeight="760"
             x:Name="Root"
             x:Class="TrueFluentPro.Views.BatchCenterView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">

    <UserControl.Styles>
        <Style Selector="ListBox.batch-package-list">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="ListBox.batch-package-list > ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <Style Selector="ListBox.batch-package-list > ListBoxItem /template/ ContentPresenter">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ClipToBounds" Value="False"/>
        </Style>

        <Style Selector="ListBox.batch-package-list > ListBoxItem:selected Border.batch-package-card">
            <Setter Property="Background" Value="#1A3B82F6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style Selector="ListBox.batch-package-list > ListBoxItem:pointerover Border.batch-package-card">
            <Setter Property="BorderBrush" Value="#804A90FF"/>
        </Style>

        <Style Selector="Border.batch-subtask-row">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="Border.batch-package-card">
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style Selector="Border.batch-inline-progress-track">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="2"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Background" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style Selector="Border.batch-inline-progress-fill">
            <Setter Property="Height" Value="2"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="RenderTransformOrigin" Value="0,0.5"/>
        </Style>

    </UserControl.Styles>

    <UserControl.Resources>
        <DataTemplate x:Key="BucketTemplate" DataType="models:BatchBucketNavItem">
            <Grid Classes="sidebar-nav-item-content" ColumnDefinitions="18,*,Auto" ColumnSpacing="10">
                <icons:Icon Grid.Column="0" Value="{Binding IconValue}" FontSize="14"/>
                <TextBlock Grid.Column="1" Classes="sidebar-nav-label" Text="{Binding Title}"/>
                <Border Grid.Column="2" Classes="sidebar-nav-badge">
                    <TextBlock Classes="sidebar-nav-badge-text" Text="{Binding Count}"/>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="PackageRowTemplate" DataType="models:BatchPackageItem">
            <Border Classes="batch-package-card"
                    Margin="0"
                    Padding="8,6"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource SubCardBorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource SubCardBackgroundBrush}"
                    PointerPressed="PackageRow_PointerPressed"
                    PointerReleased="PackageRow_PointerReleased"
                    Tapped="PackageRow_Tapped">

                <StackPanel Spacing="4">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="194" MinWidth="170"/>
                            <ColumnDefinition Width="64" MinWidth="58"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding ExpandGlyph}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSubtleBrush}"/>
                        <icons:Icon Grid.Column="1" Value="fa-solid fa-file-audio" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding DisplayName}"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="3"
                                   VerticalAlignment="Center">
                            <TextBlock.Inlines>
                                <Run Text="{Binding SummaryText}"/>
                                <Run Text="  "/>
                                <Run Text="{Binding StateText}"/>
                            </TextBlock.Inlines>
                        </TextBlock>
                        <Border Grid.Column="4" Classes="batch-inline-progress-track">
                            <Border Classes="batch-inline-progress-fill">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="{Binding Progress}"/>
                                </Border.RenderTransform>
                            </Border>
                        </Border>
                    </Grid>

                    <ItemsControl IsVisible="{Binding IsExpanded}"
                                  ItemsSource="{Binding Subtasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:BatchSubtaskItem">
                                <Border Classes="batch-subtask-row"
                                        Margin="{Binding IndentMargin}"
                                        Padding="4,2,0,2"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="0,1,0,0"
                                        PointerReleased="SubtaskRow_PointerReleased">

                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="18"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="178" MinWidth="156"/>
                                            <ColumnDefinition Width="90" MinWidth="72"/>
                                            <ColumnDefinition Width="64" MinWidth="58"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0" Width="12" Height="18" VerticalAlignment="Center">
                                            <Border Width="1"
                                                    Background="{DynamicResource BorderSubtleBrush}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Stretch"/>
                                            <Border Width="8"
                                                    Height="1"
                                                    Background="{DynamicResource BorderSubtleBrush}"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"/>
                                        </Grid>
                                        <icons:Icon Grid.Column="1" Value="{Binding IconValue}" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Title}"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding StatusText}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip.Tip="{Binding StatusText}"/>
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding Tag}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSubtleBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip.Tip="{Binding Tag}"/>
                                        <Border Grid.Column="5" Classes="batch-inline-progress-track">
                                            <Border Classes="batch-inline-progress-fill">
                                                <Border.RenderTransform>
                                                    <ScaleTransform ScaleX="{Binding Progress}"/>
                                                </Border.RenderTransform>
                                            </Border>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="12"
          Background="{DynamicResource PageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="216" MinWidth="204"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*" MinWidth="680"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Classes="nav-surface"
                BorderThickness="0,0,1,0"
                Padding="8,12,8,8">
            <Grid RowDefinitions="Auto,*" RowSpacing="4">
                <Grid Grid.Row="0"
                      Classes="secondary-nav-header"
                      RowDefinitions="Auto,*"
                      Margin="10,0,10,4">
                    <Grid Grid.Row="0"
                          Classes="secondary-nav-header-title-row"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="6">
                        <TextBlock Grid.Column="0"
                                   Classes="secondary-nav-title"
                                   Text="任务分类"/>
                    </Grid>
                    <Grid Grid.Row="1"
                          Classes="secondary-nav-header-action-row"
                          ColumnDefinitions="40,122,*"
                          ColumnSpacing="6">
                        <Button Grid.Column="0"
                                                                Classes="secondary-nav-compact"
                                                                Width="40"
                                                                Padding="0"
                                                                HorizontalContentAlignment="Center"
                                                                Command="{Binding BatchProcessing.LoadBatchTasksCommand}"
                                                                ToolTip.Tip="刷新分类">
                            <icons:Icon Value="fa-solid fa-arrows-rotate" FontSize="12"/>
                        </Button>
                        <Button Grid.Column="1"
                                Classes="secondary-nav-compact"
                                Width="122"
                                HorizontalAlignment="Left"
                                Command="{Binding BatchProcessing.StartBatchCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <icons:Icon Value="fa-solid fa-play" FontSize="12"/>
                                <TextBlock Text="全部开始"/>
                            </StackPanel>
                        </Button>
                        <Border Grid.Column="2" Background="Transparent"/>
                    </Grid>
                </Grid>

                <ListBox Grid.Row="1"
                         Classes="sidebar-nav-list"
                         ItemsSource="{Binding BatchProcessing.PackageBuckets}"
                         SelectedItem="{Binding BatchProcessing.SelectedPackageBucket, Mode=TwoWay}"
                         ItemTemplate="{StaticResource BucketTemplate}"/>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="12"
                      Background="Transparent"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeDirection="Columns"
                      ShowsPreview="True"/>

        <Border Grid.Column="2"
                Classes="app-card"
                Padding="14">
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <Button Grid.Column="1"
                            Padding="10,6"
                            Command="{Binding BatchProcessing.StartPackageCommand}"
                            CommandParameter="{Binding BatchProcessing.SelectedPackage}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <icons:Icon Value="fa-solid fa-play" FontSize="12"/>
                            <TextBlock Text="开始选中项"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2"
                            Padding="10,6"
                            Command="{Binding BatchProcessing.RefreshBatchQueueCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <icons:Icon Value="fa-solid fa-arrows-rotate" FontSize="12"/>
                            <TextBlock Text="刷新队列"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Border Grid.Row="1"
                        Classes="sub-card"
                        Padding="10">
                    <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                        <TextBlock Grid.Column="0" Text="并发数" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Width="80" Text="{Binding BatchProcessing.BatchConcurrencyLimit, Mode=TwoWay}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding BatchProcessing.BatchQueueStatusText}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSubtleBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2"
                          HorizontalScrollBarVisibility="Disabled"
                          PointerReleased="PackageArea_PointerReleased">
                    <ListBox Classes="batch-package-list"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="0,0,12,0"
                         ItemsSource="{Binding BatchProcessing.CurrentBucketPackages}"
                         SelectedItem="{Binding BatchProcessing.SelectedPackage, Mode=TwoWay}"
                         ItemTemplate="{StaticResource PackageRowTemplate}"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
