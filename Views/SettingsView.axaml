<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:TrueFluentPro.ViewModels"
             xmlns:settings="clr-namespace:TrueFluentPro.Views.Settings"
             xmlns:icons="https://github.com/projektanker/icons.avalonia"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="TrueFluentPro.Views.SettingsView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">

        <Grid RowDefinitions="*,Auto"
              Background="{DynamicResource PageBackgroundBrush}">
        <Grid Grid.Row="0"
              Margin="12,12,12,10"
              Background="{DynamicResource PageBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="216" MinWidth="204"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <!-- 左侧锚点导航 -->
        <Border Grid.Column="0"
            Classes="nav-surface"
            Background="{DynamicResource NavPanelBackgroundBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,0,1,0" Padding="8,12,8,8">
            <Grid RowDefinitions="Auto,*" RowSpacing="4">
                <Grid Grid.Row="0"
                      Classes="secondary-nav-header"
                      RowDefinitions="Auto,*"
                      Margin="10,0,10,4">
                    <Grid Grid.Row="0"
                          Classes="secondary-nav-header-title-row"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="6">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Classes="secondary-nav-title"
                                       Text="配置中心"/>
                            <TextBlock Classes="secondary-nav-note"
                                       Text="自动保存已开启"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1"
                          Classes="secondary-nav-header-action-row"
                          ColumnDefinitions="40,122,*"
                          ColumnSpacing="6">
                        <Button Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Classes="secondary-nav-compact"
                                Width="168"
                                HorizontalAlignment="Left"
                                Click="OpenConfigLocationButton_Click"
                                ToolTip.Tip="打开配置文件所在位置"
                                AutomationProperties.Name="打开配置文件位置">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <icons:Icon Value="fa-regular fa-folder-open" FontSize="12"/>
                                <TextBlock Text="打开配置位置"/>
                            </StackPanel>
                        </Button>
                        <Border Grid.Column="2" Background="Transparent"/>
                    </Grid>
                </Grid>

                <ListBox Grid.Row="1"
                         Name="NavListBox" Classes="sidebar-nav-list" SelectionMode="Single"
                         SelectionChanged="OnNavSectionChanged"
                         Background="Transparent" Margin="0,0,2,0">
                    <ListBoxItem Tag="Section_Subscription">
                        <Grid Classes="sidebar-nav-item-content" ColumnDefinitions="18,*" ColumnSpacing="10">
                            <icons:Icon Grid.Column="0" Value="fa-solid fa-microphone-lines" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="Azure Speech" VerticalAlignment="Center"/>
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Section_Endpoints">
                        <Grid Classes="sidebar-nav-item-content" ColumnDefinitions="18,*" ColumnSpacing="10">
                            <icons:Icon Grid.Column="0" Value="fa-solid fa-plug" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="AI 终结点" VerticalAlignment="Center"/>
                        </Grid>
                    </ListBoxItem>
                        <ListBoxItem Tag="Section_ModelSelection">
                            <Grid Classes="sidebar-nav-item-content" ColumnDefinitions="18,*" ColumnSpacing="10">
                                <icons:Icon Grid.Column="0" Value="fa-solid fa-robot" FontSize="14"/>
                                <TextBlock Grid.Column="1" Text="AI 资源与模型" VerticalAlignment="Center"/>
                            </Grid>
                        </ListBoxItem>
                    <ListBoxItem Tag="Section_Storage">
                        <Grid Classes="sidebar-nav-item-content" ColumnDefinitions="18,*" ColumnSpacing="10">
                            <icons:Icon Grid.Column="0" Value="fa-solid fa-hard-drive" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="录音与存储" VerticalAlignment="Center"/>
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Section_Insight">
                        <Grid Classes="sidebar-nav-item-content" ColumnDefinitions="18,*" ColumnSpacing="10">
                            <icons:Icon Grid.Column="0" Value="fa-solid fa-lightbulb" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="洞察" VerticalAlignment="Center"/>
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Section_Review">
                        <Grid Classes="sidebar-nav-item-content" ColumnDefinitions="18,*" ColumnSpacing="10">
                            <icons:Icon Grid.Column="0" Value="fa-solid fa-clipboard-list" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="复盘预设" VerticalAlignment="Center"/>
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Section_ImageGen">
                        <Grid Classes="sidebar-nav-item-content" ColumnDefinitions="18,*" ColumnSpacing="10">
                            <icons:Icon Grid.Column="0" Value="fa-solid fa-image" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="图片生成" VerticalAlignment="Center"/>
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Section_VideoGen">
                        <Grid Classes="sidebar-nav-item-content" ColumnDefinitions="18,*" ColumnSpacing="10">
                            <icons:Icon Grid.Column="0" Value="fa-solid fa-video" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="视频生成" VerticalAlignment="Center"/>
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Section_Audio">
                        <Grid Classes="sidebar-nav-item-content" ColumnDefinitions="18,*" ColumnSpacing="10">
                            <icons:Icon Grid.Column="0" Value="fa-solid fa-headphones" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="音频设备" VerticalAlignment="Center"/>
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Section_Recognition">
                        <Grid Classes="sidebar-nav-item-content" ColumnDefinitions="18,*" ColumnSpacing="10">
                            <icons:Icon Grid.Column="0" Value="fa-solid fa-wave-square" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="语音识别" VerticalAlignment="Center"/>
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Section_Text">
                        <Grid Classes="sidebar-nav-item-content" ColumnDefinitions="18,*" ColumnSpacing="10">
                            <icons:Icon Grid.Column="0" Value="fa-solid fa-closed-captioning" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="字幕与文本" VerticalAlignment="Center"/>
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Section_Transfer">
                        <Grid Classes="sidebar-nav-item-content" ColumnDefinitions="18,*" ColumnSpacing="10">
                            <icons:Icon Grid.Column="0" Value="fa-solid fa-right-left" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="配置迁移" VerticalAlignment="Center"/>
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Section_About">
                        <Grid Classes="sidebar-nav-item-content" ColumnDefinitions="18,*" ColumnSpacing="10">
                            <icons:Icon Grid.Column="0" Value="fa-solid fa-circle-info" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="关于" VerticalAlignment="Center"/>
                        </Grid>
                    </ListBoxItem>
                </ListBox>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="12"
                      Background="Transparent"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeDirection="Columns"
                      ShowsPreview="True"/>

        <!-- 右侧瀑布流内容 -->
        <ScrollViewer Grid.Column="2" Name="SettingsScroller"
                      ScrollChanged="OnSettingsScrollChanged"
                      Background="{DynamicResource PageBackgroundBrush}"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Name="SectionsPanel" Spacing="16" Margin="24,12,24,24">
                <ContentControl Name="Section_Subscription"/>
                <ContentControl Name="Section_Endpoints"/>
                <ContentControl Name="Section_ModelSelection"/>
                <ContentControl Name="Section_Storage"/>
                <ContentControl Name="Section_Insight"/>
                <ContentControl Name="Section_Review"/>
                <ContentControl Name="Section_ImageGen"/>
                <ContentControl Name="Section_VideoGen"/>
                <ContentControl Name="Section_Audio"/>
                <ContentControl Name="Section_Recognition"/>
                <ContentControl Name="Section_Text"/>
                <ContentControl Name="Section_Transfer"/>
                <ContentControl Name="Section_About"/>
            </StackPanel>
        </ScrollViewer>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
            Classes="toolbar-surface"
                BorderBrush="{DynamicResource CardBorderBrush}"
                Background="{DynamicResource NavPanelBackgroundBrush}"
                BorderThickness="0,1,0,0" Padding="12,6">
            <TextBlock Text="{Binding Settings.AutoSaveStatus}" FontSize="11" Foreground="{DynamicResource TextSubtleBrush}"/>
        </Border>
    </Grid>
</UserControl>
