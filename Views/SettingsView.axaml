<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:TrueFluentPro.ViewModels"
             xmlns:settings="clr-namespace:TrueFluentPro.Views.Settings"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="TrueFluentPro.Views.SettingsView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">

    <Grid ColumnDefinitions="180,*" RowDefinitions="*,Auto">
        <!-- 左侧锚点导航 -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0" Padding="0,12,0,0">
            <ListBox Name="NavListBox" SelectionMode="Single"
                     SelectionChanged="OnNavSectionChanged"
                     Background="Transparent" Margin="4,0">
                <ListBoxItem Tag="Section_Subscription" Content="Azure Speech"/>
                <ListBoxItem Tag="Section_Endpoints" Content="AI 终结点"/>
                <ListBoxItem Tag="Section_Audio" Content="音频设备"/>
                <ListBoxItem Tag="Section_Storage" Content="录音与存储"/>
                <ListBoxItem Tag="Section_Recognition" Content="语音识别"/>
                <ListBoxItem Tag="Section_Text" Content="字幕与文本"/>
                <ListBoxItem Tag="Section_Insight" Content="洞察"/>
                <ListBoxItem Tag="Section_Review" Content="复盘预设"/>
                <ListBoxItem Tag="Section_ImageGen" Content="图片生成"/>
                <ListBoxItem Tag="Section_VideoGen" Content="视频生成"/>
                <ListBoxItem Tag="Section_About" Content="关于"/>
            </ListBox>
        </Border>

        <!-- 右侧瀑布流内容 -->
        <ScrollViewer Grid.Column="1" Name="SettingsScroller"
                      ScrollChanged="OnSettingsScrollChanged"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Name="SectionsPanel" Spacing="16" Margin="24,12,24,24">
                <settings:SubscriptionSection  Name="Section_Subscription"/>
                <settings:EndpointsSection     Name="Section_Endpoints"/>
                <settings:AudioSection         Name="Section_Audio"/>
                <settings:StorageSection       Name="Section_Storage"/>
                <settings:RecognitionSection   Name="Section_Recognition"/>
                <settings:TextSection          Name="Section_Text"/>
                <settings:InsightSection       Name="Section_Insight"/>
                <settings:ReviewSection        Name="Section_Review"/>
                <settings:ImageGenSection      Name="Section_ImageGen"/>
                <settings:VideoGenSection      Name="Section_VideoGen"/>
                <settings:AboutSection         Name="Section_About"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 状态栏 -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Padding="12,6">
            <TextBlock Text="{Binding Settings.AutoSaveStatus}" FontSize="11" Foreground="Gray"/>
        </Border>
    </Grid>
</UserControl>
