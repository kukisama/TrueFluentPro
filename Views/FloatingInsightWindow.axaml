<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:TrueFluentPro.ViewModels"
    xmlns:controls="using:TrueFluentPro.Controls"
    x:Class="TrueFluentPro.Views.FloatingInsightWindow"
    x:DataType="vm:FloatingInsightViewModel" Title="Floating Insight"
    Width="520"
    Height="400"
    MinWidth="320"
    MinHeight="200"
    SystemDecorations="None"
    WindowStartupLocation="Manual"
    Topmost="True"
    CanResize="True"
    Background="Transparent"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaChromeHints="NoChrome"
    ExtendClientAreaTitleBarHeightHint="-1">

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Styles>

    <Border Name="MainBorder"
        Background="{DynamicResource CardBackgroundBrush}"
        CornerRadius="8"
        BorderThickness="1"
        BorderBrush="{DynamicResource CardBorderBrush}"
        Margin="5"
        BoxShadow="0 8 24 0 #120F172A">

        <Grid RowDefinitions="Auto,*,Auto">
            <!-- Title bar: draggable -->
            <Border Grid.Row="0"
                Background="Transparent"
                Cursor="Hand"
                PointerPressed="OnTitleBarPointerPressed"
                Padding="10,6">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                    <!-- Brain icon -->
                    <TextBlock Grid.Column="0" Text="🧠" FontSize="16"
                        VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="浮动洞察"
                        FontSize="13" FontWeight="SemiBold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        VerticalAlignment="Center"/>
                    <!-- Font decrease -->
                    <Button Grid.Column="2" Content="A-" Padding="6,2" Margin="4,0"
                        FontSize="11" Click="OnDecreaseFontSize"
                        ToolTip.Tip="缩小字体"/>
                    <!-- Font increase -->
                    <Button Grid.Column="3" Content="A+" Padding="6,2" Margin="0,0,4,0"
                        FontSize="11" Click="OnIncreaseFontSize"
                        ToolTip.Tip="放大字体"/>
                    <!-- Close -->
                    <Button Grid.Column="4" Content="✕" Padding="6,2"
                        FontSize="11" Click="OnCloseClick"
                        ToolTip.Tip="关闭"/>
                </Grid>
            </Border>

            <!-- Content: Markdown viewer -->
            <Border Grid.Row="1" Margin="8,0,8,8">
                <Border Padding="16,10,16,14"
                        Background="{DynamicResource SubCardBackgroundBrush}"
                        CornerRadius="6">
                    <LayoutTransformControl Name="MarkdownScaleContainer">
                        <controls:ChatMarkdownBlock Name="InsightMarkdownViewer"
                                                    Markdown="{Binding InsightMarkdown}"/>
                    </LayoutTransformControl>
                </Border>
            </Border>

            <!-- 右下角拖拽调整大小手柄 -->
            <Border Grid.Row="2" Width="16" Height="16"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Cursor="BottomRightCorner"
                    Background="Transparent"
                    PointerPressed="OnResizePointerPressed">
                <TextBlock Text="⋮⋮" FontSize="9" Foreground="{DynamicResource TextSubtleBrush}"
                           Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
