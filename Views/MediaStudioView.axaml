<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:TrueFluentPro.Controls"
        xmlns:icons="https://github.com/projektanker/icons.avalonia"

        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="TrueFluentPro.Views.MediaStudioView"
        x:CompileBindings="False">

    <UserControl.Resources>
        <controls:FilePathToBitmapConverter x:Key="FilePathToBitmapConverter"/>
        <controls:FirstFrameBadgeVisibilityConverter x:Key="FirstFrameBadgeVisibilityConverter"/>
        <controls:CitationsToUrlDictionaryConverter x:Key="CitationsToUrlDictionaryConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- 用户消息气泡 -->
        <Style Selector="Border.user-msg">
            <Setter Property="Background" Value="{DynamicResource UserMessageBrush}"/>
            <Setter Property="CornerRadius" Value="10,10,2,10"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="60,8,8,8"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
        <!-- AI 消息气泡 -->
        <Style Selector="Border.ai-msg">
            <Setter Property="Background" Value="{DynamicResource AiMessageBrush}"/>
            <Setter Property="CornerRadius" Value="10,10,10,2"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="8,8,60,8"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <!-- 参数区域标签 -->
        <Style Selector="TextBlock.param-label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <Style Selector="Grid.ref-anchor Button.ref-remove">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="Grid.ref-anchor:pointerover Button.ref-remove">
            <Setter Property="IsVisible" Value="True"/>
        </Style>
        <Style Selector="Button.ref-add">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.ref-add:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.ref-add:pressed">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <!-- 消息操作按钮：默认半透明，hover 气泡时显示，hover 按钮时高亮 -->
        <Style Selector="StackPanel.msg-actions">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="Border.ai-msg:pointerover StackPanel.msg-actions">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="StackPanel.msg-actions > Button">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="StackPanel.msg-actions > Button:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorLight2}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorLight2}"/>
        </Style>
        <Style Selector="StackPanel.msg-actions > Button:pressed">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorLight3}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>

        <Grid RowDefinitions="*,Auto"
                    Background="{DynamicResource PageBackgroundBrush}">

        <!-- ===== 主体区域（左右分栏） ===== -->
        <Grid Grid.Row="0" Margin="12,12,12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="216" MinWidth="204"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*" MinWidth="680"/>
            </Grid.ColumnDefinitions>
            <!-- 左侧会话列表 -->
            <Border Grid.Column="0"
                    Classes="nav-surface"
                    BorderThickness="0,0,1,0"
                    Padding="8,12,8,8">
                <Grid RowDefinitions="Auto,*" RowSpacing="4">
                    <Grid Grid.Row="0"
                          Classes="secondary-nav-header"
                          RowDefinitions="Auto,*"
                          Margin="10,0,10,4">
                        <Grid Grid.Row="0"
                              Classes="secondary-nav-header-title-row"
                              ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Classes="secondary-nav-title"
                                       Text="会话"/>
                        </Grid>
                        <Grid Grid.Row="1"
                              Classes="secondary-nav-header-action-row"
                              ColumnDefinitions="40,122,*"
                              ColumnSpacing="6">
                            <Button Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Classes="secondary-nav-compact"
                                    Width="168"
                                    HorizontalAlignment="Left"
                                    Command="{Binding NewSessionCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <icons:Icon Value="fa-solid fa-plus" FontSize="12"/>
                                    <TextBlock Text="新建会话"/>
                                </StackPanel>
                            </Button>
                            <Border Grid.Column="2" Background="Transparent"/>
                        </Grid>
                    </Grid>
                    <ListBox Grid.Row="1"
                             x:Name="SessionListBox"
                             Classes="sidebar-nav-list"
                             ItemsSource="{Binding Sessions}"
                             SelectedItem="{Binding CurrentSession}"
                             Margin="0" Padding="0"
                             Background="Transparent"
                             KeyDown="SessionListBox_KeyDown">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Classes="sidebar-nav-item-content"
                                      ColumnDefinitions="18,*,Auto"
                                      ColumnSpacing="10"
                                      PointerPressed="SessionItem_PointerPressed">
                                                                        <icons:Icon Grid.Column="0"
                                                                                                Value="fa-solid fa-message"
                                                                                                FontSize="14"/>
                                    <TextBlock Grid.Column="1"
                                               Classes="sidebar-nav-label"
                                               Text="{Binding SessionName}"/>
                                    <Ellipse Grid.Column="2" Classes="sidebar-nav-dot"
                                             IsVisible="{Binding HasBadge}"
                                             />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="12"
                          Background="Transparent"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ShowsPreview="True"/>

            <!-- 右侧内容区 -->
            <Grid Grid.Column="2" RowDefinitions="*,Auto"
                            x:Name="SessionViewsHost">
                            <ContentControl Content="{Binding CurrentSession}"
                                            IsVisible="{Binding HasCurrentSession}">
                                <ContentControl.ContentTemplate>
                                    <DataTemplate>
                                        <Grid RowDefinitions="*,Auto"
                                              x:Name="SessionContentRoot">

                <!-- 聊天消息区 -->
                <Border Grid.Row="0" Classes="app-card" Margin="0,0,0,10">
                    <Grid RowDefinitions="Auto,*">
                        <!-- 搜索栏（Ctrl+F 显示） -->
                        <Border Grid.Row="0" Padding="8,6" IsVisible="{Binding IsSearchVisible}"
                                Background="{DynamicResource CodeBlockBackgroundBrush}"
                                CornerRadius="6" Margin="8,4,8,4">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Grid.Column="1" x:Name="SearchTextBox"
                                         Text="{Binding SearchQuery, Mode=TwoWay}"
                                         Watermark="搜索对话内容..."
                                         FontSize="12" Padding="6,4" Height="28"/>
                                <TextBlock Grid.Column="2" Text="{Binding SearchStatus}"
                                           FontSize="11" Opacity="0.6"
                                           VerticalAlignment="Center" Margin="6,0"/>
                                <Button Grid.Column="3" Content="▲" Padding="4,2" FontSize="10"
                                        Click="SearchPrevious_Click" ToolTip.Tip="上一个"/>
                                <Button Grid.Column="4" Content="▼" Padding="4,2" FontSize="10"
                                        Click="SearchNext_Click" ToolTip.Tip="下一个"/>
                                <Button Grid.Column="5" Content="✕" Padding="4,2" FontSize="10"
                                        Click="CloseSearch_Click" Margin="4,0,0,0"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1"
                              DragDrop.AllowDrop="True">
                        <ScrollViewer x:Name="SessionScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="8"
                                      ScrollChanged="ChatScrollViewer_ScrollChanged">
                            <ItemsControl ItemsSource="{Binding Messages}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Panel>
                                            <!-- 用户消息 -->
                                            <Border Classes="user-msg" IsVisible="{Binding IsUser}"
                                                    PointerReleased="ChatMessageBorder_PointerReleased">
                                                <StackPanel Spacing="4">
                                                    <!-- 正常显示模式 -->
                                                    <SelectableTextBlock Text="{Binding Text}"
                                                             TextWrapping="Wrap"
                                                             ContextFlyout="{x:Null}"
                                                             IsVisible="{Binding IsNotEditing}"/>
                                                    <!-- 原地编辑模式 -->
                                                    <StackPanel Spacing="6" IsVisible="{Binding IsEditing}">
                                                        <TextBox Text="{Binding EditText, Mode=TwoWay}"
                                                                 AcceptsReturn="True"
                                                                 TextWrapping="Wrap"
                                                                 MinHeight="38"
                                                                 MaxHeight="160"
                                                                 Padding="8,6"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="6"
                                                                    HorizontalAlignment="Right">
                                                            <Button ToolTip.Tip="取消编辑" Padding="6,3" FontSize="11"
                                                                    Command="{Binding $parent[ItemsControl].DataContext.CancelEditCommand}"
                                                                    CommandParameter="{Binding}">
                                                                <icons:Icon Value="fa-solid fa-xmark" FontSize="12"/>
                                                            </Button>
                                                            <Button ToolTip.Tip="仅保存修改" Padding="6,3" FontSize="11"
                                                                    Command="{Binding $parent[ItemsControl].DataContext.SaveEditCommand}"
                                                                    CommandParameter="{Binding}">
                                                                <icons:Icon Value="fa-regular fa-floppy-disk" FontSize="12"/>
                                                            </Button>
                                                            <Button ToolTip.Tip="保存并重新生成回复" Padding="8,3" FontSize="11"
                                                                    Background="{DynamicResource AccentBlueBrush}" Foreground="White"
                                                                    Command="{Binding $parent[ItemsControl].DataContext.SendEditCommand}"
                                                                    CommandParameter="{Binding}">
                                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                                    <icons:Icon Value="fa-solid fa-paper-plane" FontSize="12"/>
                                                                    <TextBlock Text="发送" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                                IsVisible="{Binding IsNotEditing}">
                                                        <TextBlock Text="{Binding TimestampText}" FontSize="10"
                                                                   Foreground="{DynamicResource TimestampBrush}"
                                                                   VerticalAlignment="Center"/>
                                                        <!-- 编辑按钮 -->
                                                        <Button ToolTip.Tip="编辑" FontSize="10" Padding="4,2"
                                                                Opacity="0.6" Cursor="Hand"
                                                                Command="{Binding $parent[ItemsControl].DataContext.EditMessageCommand}"
                                                                CommandParameter="{Binding}">
                                                            <icons:Icon Value="fa-regular fa-pen-to-square" FontSize="11"/>
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <!-- AI 消息 -->
                                            <Border Classes="ai-msg" IsVisible="{Binding IsAssistant}"
                                                    PointerReleased="ChatMessageBorder_PointerReleased">
                                                <StackPanel Spacing="6">
                                                    <!-- 推理/思考折叠区（仅有推理数据时显示） -->
                                                    <StackPanel Spacing="4"
                                                                IsVisible="{Binding HasReasoning}">
                                                        <!-- 有思考内容时的展开/收缩按钮 -->
                                                        <Button Classes="pressable" Padding="6,3" FontSize="11"
                                                                Click="ToggleReasoning_Click"
                                                                HorizontalAlignment="Left"
                                                                ToolTip.Tip="展开/折叠思考过程">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <icons:Icon Value="fa-solid fa-brain" FontSize="12" VerticalAlignment="Center"/>
                                                                <TextBlock Text="思考过程" VerticalAlignment="Center"/>
                                                                <TextBlock Text="▾" FontSize="10" VerticalAlignment="Center"
                                                                           IsVisible="{Binding !IsReasoningExpanded}"/>
                                                                <TextBlock Text="▴" FontSize="10" VerticalAlignment="Center"
                                                                           IsVisible="{Binding IsReasoningExpanded}"/>
                                                            </StackPanel>
                                                        </Button>
                                                        <Border IsVisible="{Binding IsReasoningExpanded}"
                                                                Background="{DynamicResource CodeBlockBackgroundBrush}"
                                                                CornerRadius="6" Padding="10,8" Margin="0,2,0,4">
                                                            <controls:ChatMarkdownBlock Markdown="{Binding ReasoningText}"
                                                                     IsReasoning="True"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <!-- 文本内容：Markdown 渲染（支持流式 + 代码块复制） -->
                                                    <controls:ChatMarkdownBlock Markdown="{Binding Text}"
                                                        CitationUrls="{Binding Citations, Converter={StaticResource CitationsToUrlDictionaryConverter}}"/>

                                                    <!-- 搜索过程摘要 -->
                                                    <TextBlock Text="{Binding SearchSummary}"
                                                               IsVisible="{Binding HasSearchSummary}"
                                                               FontSize="10.5" Opacity="0.6"
                                                               TextWrapping="Wrap"
                                                               Margin="0,4,0,0"/>

                                                    <!-- 搜索引用来源面板 -->
                                                    <controls:CitationPanel Citations="{Binding Citations}"
                                                                            IsVisible="{Binding HasCitations}"/>

                                                    <ProgressBar IsIndeterminate="True" Height="4"
                                                                 IsVisible="{Binding IsLoading}"/>

                                                    <!-- 推理诊断状态（流式完成后显示） -->
                                                    <TextBlock Text="{Binding ReasoningStatusText}"
                                                               IsVisible="{Binding HasReasoningStatus}"
                                                               FontSize="10.5" Opacity="0.6"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0"/>

                                                    <!-- 媒体文件列表 -->
                                                    <ItemsControl ItemsSource="{Binding MediaPaths}"
                                                                  IsVisible="{Binding HasMedia}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="2" CornerRadius="6"
                                                                        Background="{DynamicResource MediaItemBrush}" Padding="4"
                                                                        Cursor="Hand"
                                                                        PointerPressed="MediaThumbnail_PointerPressed"
                                                                        Tag="{Binding $parent[ItemsControl].DataContext}">
                                                                    <Grid>
                                                                        <!-- 图片预览（点击即可大图/播放） -->
                                                                          <controls:ViewportLazyImage x:Name="PreviewImage"
                                                                                          MaxWidth="200"
                                                                                          MaxHeight="200"
                                                                                          Stretch="Uniform"
                                                                                          FilePath="{Binding}"/>

                                                                        <!-- 首帧专属播放提示 -->
                                                                        <Border HorizontalAlignment="Left"
                                                                                VerticalAlignment="Top"
                                                                                Margin="6"
                                                                                CornerRadius="8"
                                                                                Padding="10,4"
                                                                                Background="#CC000000"
                                                                                IsVisible="{Binding Converter={StaticResource FirstFrameBadgeVisibilityConverter}}">
                                                                            <TextBlock Text="▶ 播放视频"
                                                                                       FontSize="13"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="White"/>
                                                                        </Border>

                                                                        <!-- 首帧中心播放图示（更大更直观） -->
                                                                        <Border HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"
                                                                                Width="56"
                                                                                Height="56"
                                                                                CornerRadius="28"
                                                                                Background="#B3000000"
                                                                                BorderBrush="#E6FFFFFF"
                                                                                BorderThickness="2"
                                                                                IsVisible="{Binding Converter={StaticResource FirstFrameBadgeVisibilityConverter}}">
                                                                            <TextBlock Text="▶"
                                                                                       FontSize="28"
                                                                                       FontWeight="Bold"
                                                                                       Foreground="White"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       Margin="2,0,0,0"/>
                                                                        </Border>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <!-- 消息操作按钮 -->
                                                    <StackPanel Classes="msg-actions" Orientation="Horizontal" Spacing="6"
                                                                IsVisible="{Binding !IsLoading}">
                                                        <Button ToolTip.Tip="复制"
                                                                Command="{Binding $parent[ItemsControl].DataContext.CopyMessageCommand}"
                                                                CommandParameter="{Binding}">
                                                            <icons:Icon Value="fa-regular fa-copy" FontSize="13"/>
                                                        </Button>
                                                        <Button ToolTip.Tip="重新生成"
                                                                IsVisible="{Binding IsTextContent}"
                                                                Command="{Binding $parent[ItemsControl].DataContext.RegenerateMessageCommand}"
                                                                CommandParameter="{Binding}">
                                                            <icons:Icon Value="fa-solid fa-rotate" FontSize="13"/>
                                                        </Button>
                                                        <Button ToolTip.Tip="从此处创建对话分支"
                                                                Command="{Binding $parent[ItemsControl].DataContext.ForkFromMessageCommand}"
                                                                CommandParameter="{Binding}">
                                                            <icons:Icon Value="fa-solid fa-code-branch" FontSize="13"/>
                                                        </Button>
                                                        <Button ToolTip.Tip="删除"
                                                                Command="{Binding $parent[ItemsControl].DataContext.DeleteMessageCommand}"
                                                                CommandParameter="{Binding}">
                                                            <icons:Icon Value="fa-regular fa-trash-can" FontSize="13"/>
                                                        </Button>
                                                    </StackPanel>

                                                    <!-- Token 用量显示 -->
                                                    <TextBlock Text="{Binding TokenUsageText}"
                                                               IsVisible="{Binding HasTokenUsage}"
                                                               FontSize="10" Opacity="0.5"
                                                               Margin="0,1,0,0"/>

                                                    <TextBlock Text="{Binding TimestampText}" FontSize="10"
                                                               Foreground="{DynamicResource TimestampBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </Panel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                                        <StackPanel HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom"
                                                    Margin="0,0,12,12"
                                                    Spacing="6"
                                                    IsHitTestVisible="True">
                                            <Button ToolTip.Tip="搜索 (Ctrl+F)" Padding="10,4" FontSize="11"
                                                    Click="ToggleSearch_Click">
                                                <icons:Icon Value="fa-solid fa-magnifying-glass" FontSize="13"/>
                                            </Button>
                                            <Button ToolTip.Tip="导出对话" Padding="10,4" FontSize="11"
                                                    Command="{Binding ExportConversationCommand}">
                                                <icons:Icon Value="fa-solid fa-arrow-up-from-bracket" FontSize="13"/>
                                            </Button>
                                            <Button x:Name="ScrollToTopButton"
                                                    ToolTip.Tip="回到顶部"
                                                    IsVisible="False"
                                                    Padding="10,4"
                                                    Click="ScrollToTop_Click">
                                                <icons:Icon Value="fa-solid fa-arrow-up" FontSize="13"/>
                                            </Button>
                                            <Button x:Name="ScrollToBottomButton"
                                                    ToolTip.Tip="回到底部"
                                                    IsVisible="False"
                                                    Padding="10,4"
                                                    Click="ScrollToBottom_Click">
                                                <icons:Icon Value="fa-solid fa-arrow-down" FontSize="13"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    </Grid>
                                </Border>

                <!-- ===== 底部输入区 ===== -->
                <Border Grid.Row="1" Classes="app-card" Padding="12,10">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                        <!-- 快捷短语行（文本模式下可见） -->
                        <ItemsControl Grid.Row="0" ItemsSource="{Binding QuickPhrases}"
                                      IsVisible="{Binding IsTextMode}"
                                      Margin="0,0,0,4">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Title}" Padding="8,3" FontSize="11"
                                            Margin="0,0,4,2" Opacity="0.8" Cursor="Hand"
                                            Tag="{Binding Content}"
                                            Click="QuickPhrase_Click"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 参数行 -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,6">
                            <!-- 模式切换（三选一） -->
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <ToggleButton Content="💬 文字"
                                              IsChecked="{Binding IsTextMode}"
                                              Padding="6,3"/>
                                <ToggleButton Content="🖼️ 图片"
                                              IsChecked="{Binding IsImageMode}"
                                              Padding="6,3"/>
                                <ToggleButton Content="🎬 视频"
                                              IsChecked="{Binding IsVideoMode}"
                                              Padding="6,3"/>
                            </StackPanel>

                            <Border Width="1" Background="{DynamicResource BorderMediumBrush}" Margin="4,0"/>

                            <!-- 思考开关（仅文本模式） -->
                            <ToggleButton IsChecked="{Binding EnableReasoning}"
                                          IsVisible="{Binding IsTextMode}"
                                          Padding="5,3"
                                          ToolTip.Tip="启用模型推理/思考过程">
                                <icons:Icon Value="fa-regular fa-circle-question" FontSize="14"/>
                            </ToggleButton>

                            <!-- Web 搜索开关（仅文本模式） -->
                            <ToggleButton IsChecked="{Binding EnableWebSearch}"
                                          IsVisible="{Binding IsTextMode}"
                                          Padding="5,3"
                                          ToolTip.Tip="启用 Web 搜索增强（发送前自动搜索相关信息）">
                                <icons:Icon Value="fa-solid fa-globe" FontSize="14"/>
                            </ToggleButton>

                            <!-- 图片参数 -->
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        IsVisible="{Binding IsImageMode}">
                                <TextBlock Classes="param-label" Text="尺寸:"/>
                                <ComboBox ItemsSource="{Binding ImageSizeOptions}"
                                          SelectedItem="{Binding ImageSize}"
                                          Width="120" Padding="4,2" FontSize="12"/>
                                <TextBlock Classes="param-label" Text="质量:"/>
                                <ComboBox ItemsSource="{Binding ImageQualityOptions}"
                                          SelectedItem="{Binding ImageQuality}"
                                          Width="80" Padding="4,2" FontSize="12"/>
                                <TextBlock Classes="param-label" Text="格式:"/>
                                <ComboBox ItemsSource="{Binding ImageFormatOptions}"
                                      SelectedItem="{Binding ImageFormat}"
                                      Width="80" Padding="4,2" FontSize="12"/>
                                <TextBlock Classes="param-label" Text="数量:"/>
                                <ComboBox ItemsSource="{Binding ImageCountOptions}"
                                      SelectedItem="{Binding ImageCount}"
                                      Width="70" Padding="4,2" FontSize="12"/>
                            </StackPanel>

                            <!-- 视频参数 -->
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        IsVisible="{Binding IsVideoMode}">
                                <TextBlock Classes="param-label" Text="比例:"/>
                                <ComboBox ItemsSource="{Binding VideoAspectRatioOptions}"
                                      SelectedItem="{Binding VideoAspectRatio}"
                                      Width="70" Padding="4,2" FontSize="12"/>
                                <TextBlock Classes="param-label" Text="分辨率:"/>
                                <ComboBox ItemsSource="{Binding VideoResolutionOptions}"
                                      SelectedItem="{Binding VideoResolution}"
                                      Width="80" Padding="4,2" FontSize="12"/>
                                <TextBlock Classes="param-label" Text="时长:"/>
                                <ComboBox ItemsSource="{Binding VideoDurationOptions}"
                                      SelectedItem="{Binding VideoSeconds}"
                                      Width="70" Padding="4,2" FontSize="12"/>
                                <TextBlock Classes="param-label" Text="数量:"/>
                                <ComboBox ItemsSource="{Binding VideoCountOptions}"
                                      SelectedItem="{Binding VideoVariants}"
                                      Width="60" Padding="4,2" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 输入行 -->
                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                            <Grid Grid.Column="0" RowDefinitions="Auto,Auto">
                                <Border Grid.Row="0" Classes="sub-card"
                                        BorderBrush="{DynamicResource InputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="6"
                                        Margin="0,0,0,6"
                                        IsVisible="{Binding HasReferenceImage}">
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Disabled">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ItemsControl ItemsSource="{Binding ReferenceImagePaths}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="6"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Classes="ref-anchor" Width="52" Height="52">
                                                            <Border Background="Transparent"
                                                                    BorderBrush="{DynamicResource ThumbnailBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4"
                                                                    Cursor="Hand"
                                                                    PointerPressed="ReferenceImageThumbnail_PointerPressed"
                                                                    ToolTip.Tip="点击裁切为当前视频目标尺寸">
                                                                <Image Stretch="UniformToFill"
                                                                       Source="{Binding ., Converter={StaticResource FilePathToBitmapConverter}}"/>
                                                            </Border>
                                                                <Button Classes="ref-remove"
                                                                    Width="14"
                                                                    Height="14"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Top"
                                                                    Margin="0,-5,-5,0"
                                                                    Padding="0"
                                                                    FontSize="9"
                                                                    FontWeight="Bold"
                                                                    Content="×"
                                                                    HorizontalContentAlignment="Center"
                                                                    VerticalContentAlignment="Center"
                                                                    Background="#CC000000"
                                                                    Foreground="White"
                                                                    BorderThickness="0"
                                                                    CornerRadius="7"
                                                                    Command="{Binding $parent[ItemsControl].DataContext.RemoveReferenceImageCommand}"
                                                                    CommandParameter="{Binding .}"
                                                                    ToolTip.Tip="移除此参考图"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Button Classes="ref-add"
                                                    IsVisible="{Binding CanAddMoreReferenceImages}"
                                                    Width="52"
                                                    Height="52"
                                                    Padding="0"
                                                    FontSize="18"
                                                    Content="＋"
                                                    Click="AttachReferenceImage_Click"
                                                    ToolTip.Tip="添加参考图（最多8张，支持 Ctrl+V）"/>

                                            <TextBlock VerticalAlignment="Center"
                                                       Margin="4,0,0,0"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       Text="{Binding ReferenceImageCount, StringFormat=参考图: {0}/8}"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                    <Button Grid.Column="0"
                                            Classes="ref-add"
                                            IsVisible="{Binding CanAddMoreReferenceImages}"
                                            Width="36"
                                            Height="38"
                                            Padding="0"
                                            FontSize="16"
                                            Content="🖼"
                                            Click="AttachReferenceImage_Click"
                                            ToolTip.Tip="添加参考图（最多8张，支持 Ctrl+V）"/>

                                    <TextBox x:Name="PromptTextBox"
                                             Grid.Column="1"
                                             Text="{Binding PromptText}"
                                             Watermark="请输入内容... (Ctrl+Enter 发送)"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MaxHeight="80"
                                             MinHeight="38"
                                             Padding="8,6"/>
                                </Grid>
                            </Grid>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="8,0,0,0"
                                        VerticalAlignment="Bottom">
                                <!-- 文本模式：发送/停止 -->
                                <Button Classes="pressable" Content="发送" Command="{Binding GenerateCommand}"
                                        IsVisible="{Binding IsTextMode}"
                                        Padding="16,8" FontWeight="SemiBold"
                                        Background="{DynamicResource AccentBlueBrush}" Foreground="White"/>
                                <Button Content="停止" Command="{Binding StopChatCommand}"
                                        IsVisible="{Binding IsChatStreaming}"
                                        Padding="10,8"/>
                                <!-- 媒体模式：生成/取消 -->
                                <Button Classes="pressable" Content="生成" Command="{Binding GenerateCommand}"
                                        IsVisible="{Binding !IsTextMode}"
                                        Padding="16,8" FontWeight="SemiBold"
                                        Background="{DynamicResource AccentBlueBrush}" Foreground="White"/>
                                <Button Content="取消" Command="{Binding CancelCommand}"
                                        Padding="10,8"
                                        IsVisible="{Binding IsGenerating}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="3" Margin="42,4,0,0" Spacing="2">
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource WarningBrush}"
                                       IsVisible="{Binding IsVideoReferenceLimitExceeded}"
                                       Text="{Binding VideoReferenceLimitHint}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource WarningBrush}"
                                       IsVisible="{Binding IsReferenceImageSizeMismatch}"
                                       Text="{Binding ReferenceImageValidationHint}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource SuccessTextBrush}"
                                       IsVisible="{Binding IsReferenceImageSizeMatched}"
                                       Text="{Binding ReferenceImageValidationHint}"/>
                        </StackPanel>
                    </Grid>
                </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
            </Grid>

            <!-- 无会话提示 -->
            <TextBlock Grid.Column="2"
                       Text="请新建会话开始使用 Media Studio"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="16" Foreground="{DynamicResource TextPlaceholderBrush}"
                       IsVisible="{Binding !HasCurrentSession}"/>
        </Grid>

        <!-- ===== 底部状态栏 ===== -->
        <Border Grid.Row="1" Classes="toolbar-surface"
            Background="{DynamicResource NavPanelBackgroundBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="12,6">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           FontSize="12" Foreground="{DynamicResource TextSubtleBrush}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextSubtleBrush}" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="活跃任务: {0}">
                                <Binding Path="ActiveTaskCount"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
