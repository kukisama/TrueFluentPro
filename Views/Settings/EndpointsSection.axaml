<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrueFluentPro.ViewModels.Settings"
             xmlns:models="using:TrueFluentPro.Models"
             xmlns:controls="clr-namespace:TrueFluentPro.Controls"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             xmlns:icons="https://github.com/projektanker/icons.avalonia"
             x:Name="Root"
             x:Class="TrueFluentPro.Views.Settings.EndpointsSection"
             x:DataType="vm:EndpointsSectionVM"
             x:CompileBindings="False">
        <Border Classes="app-card"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8" Padding="20">
        <Border.Styles>
            <Style Selector="Border.endpoint-disabled-card">
                <Setter Property="Background" Value="#07A1A1AA"/>
                <Setter Property="BorderBrush" Value="#80A1A1AA"/>
            </Style>
            <Style Selector="TextBlock.endpoint-disabled-text">
                <Setter Property="Foreground" Value="#7A7A7A"/>
            </Style>
            <Style Selector="Border.endpoint-disabled-panel">
                <Setter Property="Background" Value="#06A1A1AA"/>
                <Setter Property="BorderBrush" Value="#80A1A1AA"/>
            </Style>
        </Border.Styles>
        <StackPanel Spacing="12">
            <TextBlock Text="AI 终结点管理" Theme="{StaticResource SubtitleTextBlockStyle}"/>
            <Separator/>
            <TextBlock Text="统一管理 AI 服务终结点与模型注册" Classes="section-description"/>

            <Grid ColumnDefinitions="172,*" ColumnSpacing="12" MinHeight="340">
                <!-- 终结点列表 -->
                <Border Grid.Column="0" Classes="sub-card" BorderBrush="{DynamicResource SubCardBorderBrush}" BorderThickness="1" CornerRadius="4" MinHeight="320">
                    <Grid RowDefinitions="*,Auto">
                        <Grid Grid.Row="0">
                            <ListBox x:Name="EndpointsListBox"
                                     ItemsSource="{Binding Endpoints}"
                                     SelectedItem="{Binding SelectedEndpoint, Mode=TwoWay}"
                                     SelectionMode="Single"
                                     PointerReleased="EndpointsListBox_PointerReleased">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="models:AiEndpoint">
                                        <Border Margin="4" Padding="8" CornerRadius="6"
                                                Classes.endpoint-disabled-card="{Binding !IsEnabled}"
                                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                <Border Width="32" Height="32">
                                                    <svg:Svg Path="{Binding EndpointTypeIconAssetPath}"
                                                             Stretch="Uniform"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Spacing="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" TextWrapping="Wrap"
                                                               Classes.endpoint-disabled-text="{Binding !IsEnabled}"/>
                                                    <TextBlock Text="已停用"
                                                               FontSize="10"
                                                               Foreground="#7A7A7A"
                                                               IsVisible="{Binding !IsEnabled}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Border Background="#08FFFFFF" IsHitTestVisible="False"
                                    IsVisible="{Binding !HasEndpoints}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6" Margin="16">
                                    <TextBlock Text="还没有 AI 终结点" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="点左下角“添加”，先建一个可编辑的终结点。"
                                               Foreground="Gray" FontSize="11" TextAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Button Grid.Row="1"
                            Margin="8"
                            Padding="0,10"
                            FontSize="13"
                            FontWeight="Bold"
                            HorizontalAlignment="Stretch"
                            Click="CreateEndpoint_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <icons:Icon Value="fa-solid fa-plus" FontSize="12"/>
                                <TextBlock Text="添加" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- 终结点详情 -->
                <StackPanel Grid.Column="1" Spacing="8" HorizontalAlignment="Left"
                            Opacity="{Binding SelectedEndpointOpacity}"
                            IsVisible="{Binding SelectedEndpoint, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Border Classes="sub-card"
                            BorderBrush="{DynamicResource SubCardBorderBrush}"
                            Classes.endpoint-disabled-panel="{Binding !SelectedEndpoint.IsEnabled}"
                            BorderThickness="1" CornerRadius="8" Padding="12" MaxWidth="520">
                        <StackPanel Spacing="4">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                                <Border Grid.Column="0" Width="36" Height="36">
                                    <svg:Svg Path="{Binding SelectedEndpoint.EndpointTypeIconAssetPath}"
                                             Stretch="Uniform"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedEndpoint.EndpointTypeDisplayName}" FontWeight="Bold"/>
                                    <TextBlock Text="右键左侧列表可编辑分类或删除终结点" FontSize="11" Foreground="Gray"/>
                                    <TextBlock Text="当前终结点已停用" FontSize="11" Foreground="#7A7A7A"
                                               IsVisible="{Binding !SelectedEndpoint.IsEnabled}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="2"
                                          Margin="8,0,0,0"
                                          Content="启用"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding SelectedEndpoint.IsEnabled, Mode=TwoWay}"/>
                                <Button Grid.Column="3"
                                        Width="36"
                                        Height="36"
                                        Padding="0"
                                        VerticalContentAlignment="Center"
                                        HorizontalContentAlignment="Center"
                                        Click="ShowEndpointInfo_Click"
                                        ToolTip.Tip="点击查看：文字 / 图片 / 视频 / 语音转写 / 文字转语音各能力的认证方式、接口路线与拼装后的 URL 示例">
                                    <icons:Icon Value="fa-solid fa-circle-info" FontSize="15"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <StackPanel Spacing="5">
                        <TextBlock Text="终结点名称"/>
                        <TextBox Text="{Binding SelectedEndpoint.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Watermark="例如: t99e"
                                 Width="420"
                                 MaxWidth="420"
                                 HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <TextBlock Text="API 地址"/>
                        <TextBox Text="{Binding SelectedEndpoint.BaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Watermark="例如: https://api.openai.com"
                                 Width="420"
                                 MaxWidth="420"
                                 HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <TextBlock Text="API 版本（可选）"/>
                        <TextBox Text="{Binding SelectedEndpoint.ApiVersion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Watermark="{Binding SelectedEndpointApiVersionWatermark}"
                                 Width="420"
                                 MaxWidth="420"
                                 HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding SelectedEndpointApiVersionNote}"
                                   FontSize="11"
                                   Foreground="Gray"
                                   TextWrapping="Wrap"
                                   Width="420"
                                   MaxWidth="420"
                                   HorizontalAlignment="Left"
                                   IsVisible="{Binding SelectedEndpointApiVersionNote, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>

                    <StackPanel Spacing="5" IsVisible="{Binding CanSelectedEndpointUseAad}">
                        <TextBlock Text="认证方式"/>
                        <ComboBox Width="420"
                                  MaxWidth="420"
                                  HorizontalAlignment="Left"
                                  SelectedIndex="{Binding SelectedEndpointAuthMode, Mode=TwoWay}">
                            <ComboBoxItem Content="API Key (默认)"/>
                            <ComboBoxItem Content="Microsoft Entra ID (AAD)"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Spacing="5" IsVisible="{Binding !IsSelectedEndpointAad}">
                        <TextBlock Text="API 密钥"/>
                        <Grid ColumnDefinitions="420,Auto" ColumnSpacing="8" HorizontalAlignment="Left">
                            <TextBox Grid.Column="0"
                                     Text="{Binding SelectedEndpoint.ApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Watermark="sk-..."
                                     PasswordChar="*"
                                     MaxWidth="420"/>
                            <Button Grid.Column="1"
                                    Width="36"
                                    Height="32"
                                    ToolTip.Tip="复制密钥"
                                    Click="CopyApiKey_Click">
                                <icons:Icon Value="fa-regular fa-copy" FontSize="13"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                    <StackPanel Spacing="5" IsVisible="{Binding IsSelectedEndpointAad}">
                        <TextBlock Text="Tenant ID"/>
                        <TextBox Text="{Binding SelectedEndpoint.AzureTenantId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Watermark="Azure AD Tenant ID"
                                 Width="420"
                                 MaxWidth="420"
                                 HorizontalAlignment="Left"/>
                        <TextBlock Text="Client ID（可选）"/>
                        <TextBox Text="{Binding SelectedEndpoint.AzureClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Watermark="Azure AD Client ID；留空时使用默认公共客户端"
                                 Width="420"
                                 MaxWidth="420"
                                 HorizontalAlignment="Left"/>
                        <controls:AadLoginPanel x:Name="EndpointAadLoginPanel"
                                                  Margin="0,4,0,0"
                                                  HideTenantClientFields="True"/>
                    </StackPanel>

                    <Separator Margin="0,6,0,6"/>
                    <TextBlock Text="模型列表" FontWeight="Bold"/>
                    <TextBlock Text="点击模型条目展开编辑；新建后会直接展开并把光标放到模型 ID。" Classes="field-note"/>
                    <ItemsControl ItemsSource="{Binding SelectedEndpointModels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:AiModelEntry">
                                <Border Name="ModelItemRoot" BorderBrush="{DynamicResource SubCardBorderBrush}" BorderThickness="1" CornerRadius="4"
                                        Margin="0,2" Tag="{Binding}">
                                    <StackPanel>
                                        <!-- 折叠头部：点击展开/收缩 -->
                                        <Border Name="ModelHeaderBorder" Padding="8,6" Cursor="Hand"
                                                PointerPressed="ModelHeader_PointerPressed"
                                                Tag="{Binding}"
                                                Background="Transparent">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <TextBlock Grid.Column="0" Text="▶" FontSize="10"
                                                           VerticalAlignment="Center" Margin="0,0,6,0"
                                                           Name="ModelExpandIcon"/>
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayTitle}" FontSize="11" VerticalAlignment="Center"/>
                                                <Button Grid.Column="2" Padding="4,2" FontSize="10"
                                                        VerticalAlignment="Center"
                                                        Click="RemoveModel_Click" Tag="{Binding}"
                                                        ToolTip.Tip="删除模型">
                                                    <icons:Icon Value="fa-solid fa-xmark" FontSize="10"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                        <!-- 展开内容：默认隐藏 -->
                                        <StackPanel Name="ModelDetailPanel" IsVisible="False"
                                                    Spacing="4" Margin="8,0,8,6">
                                            <Grid ColumnDefinitions="80,*" ColumnSpacing="6">
                                                <TextBlock Grid.Column="0" Text="模型 ID:" FontSize="11" VerticalAlignment="Center"/>
                                                <TextBox Name="ModelIdTextBox" Grid.Column="1"
                                                         Text="{Binding ModelId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Watermark="例如：gpt-4o-mini、gpt-image-1、sora-2" FontSize="11" Padding="4,2"/>
                                            </Grid>
                                                                                        <Grid ColumnDefinitions="120,*" ColumnSpacing="6"
                                                  IsVisible="{Binding #Root.DataContext.IsSelectedEndpointAzure}">
                                                                                                <TextBlock Grid.Column="0" Text="Azure 部署名:" FontSize="11" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Text="{Binding DeploymentName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                                                 Watermark="旧配置里的“模型名称”；留空默认用模型 ID" FontSize="11" Padding="4,2"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="80,*" ColumnSpacing="6">
                                                <TextBlock Grid.Column="0" Text="能力:" FontSize="11" VerticalAlignment="Center"/>
                                                <ComboBox Grid.Column="1" MinWidth="120" FontSize="11" Padding="4,2"
                                                          Tag="{Binding}"
                                                          Loaded="ModelCapabilityCombo_Loaded"
                                                          SelectionChanged="ModelCapability_SelectionChanged">
                                                    <ComboBox.Items>
                                                        <ComboBoxItem Content="未选择" Tag="None"/>
                                                        <ComboBoxItem Content="文字" Tag="Text"/>
                                                        <ComboBoxItem Content="图片" Tag="Image"/>
                                                        <ComboBoxItem Content="视频" Tag="Video"/>
                                                        <ComboBoxItem Content="语音转文字" Tag="SpeechToText"/>
                                                        <ComboBoxItem Content="文字转语音" Tag="TextToSpeech"/>
                                                    </ComboBox.Items>
                                                </ComboBox>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <Button Padding="8,4" FontSize="11"
                                Click="AddModel_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <icons:Icon Value="fa-solid fa-plus" FontSize="11"/>
                                <TextBlock Text="添加空模型" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Padding="8,4" FontSize="11"
                                Command="{Binding DiscoverModelsCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <icons:Icon Value="fa-solid fa-arrows-rotate" FontSize="11"/>
                                <TextBlock Text="从终结点拉取模型" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="{Binding EndpointDiscoveryStatus}" FontSize="11" Foreground="Gray" TextWrapping="Wrap"
                               IsVisible="{Binding EndpointDiscoveryStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <ItemsControl ItemsSource="{Binding DiscoveredModelIds}" IsVisible="{Binding HasDiscoveredModels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="x:String">
                                <Border Classes="sub-card" BorderBrush="{DynamicResource SubCardBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,2" Padding="8,6">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <TextBlock Grid.Column="0" Text="{Binding .}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Padding="8,2" Tag="{Binding .}"
                                                Click="AddDiscoveredModel_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <icons:Icon Value="fa-solid fa-plus" FontSize="10"/>
                                                <TextBlock Text="添加" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <Border Grid.Column="1" Classes="sub-card" CornerRadius="8" BorderBrush="{DynamicResource SubCardBorderBrush}"
                        BorderThickness="1" Padding="24" IsVisible="{Binding ShowEmptyState}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10" Margin="12">
                        <TextBlock Text="先创建一个 AI 终结点" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                        <TextBlock Text="先选终结点 API 类型，再填写地址与密钥；高级路由默认已按模板注入。"
                                   Foreground="Gray" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="420"/>
                        <Button Padding="12,6" Click="CreateEndpoint_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <icons:Icon Value="fa-solid fa-plus" FontSize="12"/>
                                <TextBlock Text="创建第一个终结点" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
