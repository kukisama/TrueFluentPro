<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrueFluentPro.ViewModels"
             xmlns:icons="https://github.com/projektanker/icons.avalonia"
             x:Class="TrueFluentPro.Views.Settings.ModelSelectionSection"
             x:DataType="vm:SettingsViewModel"
             x:CompileBindings="False">
    <Border Classes="app-card"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="20">
        <StackPanel Spacing="12">
            <TextBlock Text="模型与资源" Theme="{StaticResource SubtitleTextBlockStyle}"/>
            <TextBlock Classes="field-note" TextWrapping="Wrap" Text="集中管理配置中心需要先选择的模型与批量转写资源；后续新增入口也优先继续放在这里。"/>
            <Separator/>

            <Border BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="复盘字幕来源" FontWeight="Bold"/>
                        <TextBlock Classes="field-note" TextWrapping="Wrap" Text="不再单独选择字幕来源；复盘 / 批处理会直接跟随首页当前选中的语音资源。"/>
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="当前来源"/>
                        <Border BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding ReviewSubtitleSourceDisplayText}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <TextBlock Classes="field-note" TextWrapping="Wrap" Text="{Binding ReviewSubtitleSourceDescription}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left">
                        <TextBox Width="340"
                                 MaxWidth="340"
                                 Text="{Binding BatchStorageConnectionString, Mode=TwoWay}"
                                 Watermark="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=..."/>
                        <Button Width="82"
                                VerticalAlignment="Center"
                                Command="{Binding ValidateBatchStorageCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <icons:Icon Value="fa-solid fa-check" FontSize="12"/>
                                <TextBlock Text="验证" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBlock Classes="hint-text" Text="{Binding BatchStorageStatus}"/>

                    <TextBlock Classes="hint-text" Text="首页当前资源若是 Microsoft Speech，需要先验证存储账号；若是 AI 语音资源，需要先在 &quot;语音识别&quot; 里选好批量语音转写模型。"/>
                </StackPanel>
            </Border>

            <Border BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14">
                <StackPanel Spacing="8">
                    <StackPanel Spacing="2">
                        <TextBlock Text="模型选择" FontWeight="Bold"/>
                        <TextBlock Classes="field-note" TextWrapping="Wrap" Text="统一管理配置中心使用的默认模型；悬停到名称或下拉框即可查看用途说明。"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="8"
                          ColumnSpacing="8">
                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="洞察模型:"
                                   VerticalAlignment="Center"
                                   ToolTip.Tip="实时洞察默认使用的文本模型。"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" MinWidth="260"
                                  ItemsSource="{Binding TextModels}"
                                  SelectedItem="{Binding SelectedInsightModel, Mode=TwoWay}"
                                  ToolTip.Tip="实时洞察默认使用的文本模型。"/>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="快问模型:"
                                   VerticalAlignment="Center"
                                   ToolTip.Tip="快问交互默认使用的文本模型。"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" MinWidth="260"
                                  ItemsSource="{Binding TextModels}"
                                  SelectedItem="{Binding SelectedQuickModel, Mode=TwoWay}"
                                  ToolTip.Tip="快问交互默认使用的文本模型。"/>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Text="总结模型:"
                                   VerticalAlignment="Center"
                                   ToolTip.Tip="总结输出默认使用的文本模型。"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" MinWidth="260"
                                  ItemsSource="{Binding TextModels}"
                                  SelectedItem="{Binding SelectedSummaryModel, Mode=TwoWay}"
                                  ToolTip.Tip="总结输出默认使用的文本模型。"/>

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Text="复盘模型:"
                                   VerticalAlignment="Center"
                                   ToolTip.Tip="复盘工作流默认使用的文本模型。"/>
                        <ComboBox Grid.Row="3"
                                  Grid.Column="1"
                                  MinWidth="260"
                                  ItemsSource="{Binding ReviewTextModels}"
                                  SelectedItem="{Binding SelectedReviewModel, Mode=TwoWay}"
                                  ToolTip.Tip="复盘工作流默认使用的文本模型。"/>

                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Text="图片模型:"
                                   VerticalAlignment="Center"
                                   ToolTip.Tip="图片生成默认使用的模型；仅显示具有 [图片] 能力的终结点模型。"/>
                        <ComboBox Grid.Row="4"
                                  Grid.Column="1"
                                  MinWidth="260"
                                  ItemsSource="{Binding ImageModels}"
                                  SelectedItem="{Binding SelectedImageModel, Mode=TwoWay}"
                                  ToolTip.Tip="图片生成默认使用的模型；仅显示具有 [图片] 能力的终结点模型。"/>

                        <TextBlock Grid.Row="5"
                                   Grid.Column="0"
                                   Text="视频模型:"
                                   VerticalAlignment="Center"
                                   ToolTip.Tip="视频生成默认使用的模型；仅显示具有 [视频] 能力的终结点模型。"/>
                        <ComboBox Grid.Row="5"
                                  Grid.Column="1"
                                  MinWidth="260"
                                  ItemsSource="{Binding VideoModels}"
                                  SelectedItem="{Binding SelectedVideoModel, Mode=TwoWay}"
                                  ToolTip.Tip="视频生成默认使用的模型；仅显示具有 [视频] 能力的终结点模型。"/>

                        <CheckBox Grid.Row="6"
                                  Grid.Column="0"
                                  Margin="0,4,0,0"
                                  Content="创作工坊默认启用思考"
                                  FontSize="11"
                                  IsChecked="{Binding StudioDefaultEnableReasoning, Mode=TwoWay}"
                                  ToolTip.Tip="控制创作工坊新建文本会话时，底部思考按钮默认是否开启。"/>

                        <CheckBox Grid.Row="6"
                                  Grid.Column="1"
                                  Margin="0,4,0,0"
                                  Content="复盘 / 总结启用思考"
                                  FontSize="11"
                                  IsChecked="{Binding SummaryEnableReasoning, Mode=TwoWay}"
                                  ToolTip.Tip="当前这一个开关会同时影响复盘与总结相关链路；若模型或接口不支持，运行时会自动降级为非思考模式。"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>