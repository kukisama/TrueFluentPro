<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrueFluentPro.ViewModels.Settings"
             xmlns:icons="https://github.com/projektanker/icons.avalonia"
             x:Class="TrueFluentPro.Views.Settings.StorageSection"
             x:DataType="vm:StorageSectionVM"
             x:CompileBindings="False">
        <Border Classes="app-card"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8" Padding="20">
        <StackPanel Spacing="12">
            <TextBlock Text="录音与存储" Theme="{StaticResource SubtitleTextBlockStyle}"/>
            <Separator/>

            <TextBlock Text="录音设置" FontWeight="Bold"/>
            <CheckBox Content="边翻译边录音（直接输出 MP3）"
                      IsChecked="{Binding EnableRecording, Mode=TwoWay}"/>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="MP3 码率 (kbps)" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding RecordingMp3BitrateKbps, Mode=TwoWay}"
                               Minimum="32" Maximum="320" Width="120" FormatString="F0"
                               IsEnabled="{Binding EnableRecording}"/>
            </StackPanel>

            <Separator Margin="0,8,0,8"/>
            <TextBlock Text="会话目录" FontWeight="Bold"/>
            <StackPanel Spacing="5">
                <TextBlock Text="会话记录保存目录"/>
                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left">
                    <TextBox Width="280" MaxWidth="280"
                             Text="{Binding SessionDirectory, Mode=TwoWay}"
                             Watermark="留空使用默认目录"/>
                    <Button Width="36"
                            VerticalAlignment="Center"
                            ToolTip.Tip="浏览目录"
                            Click="BrowseSessionDirectory_Click">
                        <icons:Icon Value="fa-regular fa-folder-open" FontSize="13"/>
                    </Button>
                </StackPanel>
            </StackPanel>

            <Separator Margin="0,8,0,8"/>
            <TextBlock Text="批量转写" FontWeight="Bold"/>
            <StackPanel Spacing="5">
                <TextBlock Text="存储账号连接字符串"/>
                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left">
                    <TextBox Width="280" MaxWidth="280"
                             Text="{Binding BatchStorageConnectionString, Mode=TwoWay}"
                             Watermark="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=..."/>
                    <Button Width="82"
                            VerticalAlignment="Center"
                            Command="{Binding ValidateBatchStorageCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <icons:Icon Value="fa-solid fa-check" FontSize="12"/>
                            <TextBlock Text="验证" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Text="{Binding BatchStorageStatus}" FontSize="10" Foreground="Gray" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="诊断日志"/>
                <ComboBox MinWidth="220"
                          SelectedIndex="{Binding BatchLogLevelIndex, Mode=TwoWay}">
                    <ComboBoxItem Content="关闭"/>
                    <ComboBoxItem Content="仅失败"/>
                    <ComboBoxItem Content="成功 + 失败"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="强制重新生成"/>
                <CheckBox Content="批量处理：强制重新生成字幕和复盘"
                          IsChecked="{Binding BatchForceRegeneration, Mode=TwoWay}"/>
                <CheckBox Content="右键处理：强制重新生成字幕和复盘"
                          IsChecked="{Binding ContextMenuForceRegeneration, Mode=TwoWay}"/>
            </StackPanel>

            <Separator Margin="0,8,0,8"/>
            <TextBlock Text="批量字幕切分" FontWeight="Bold"/>
            <CheckBox Content="启用按句子切分"
                      IsChecked="{Binding EnableBatchSentenceSplit, Mode=TwoWay}"/>
            <CheckBox Content="逗号也作为断句"
                      IsChecked="{Binding BatchSplitOnComma, Mode=TwoWay}"/>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="每句最大字数" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding BatchMaxChars, Mode=TwoWay}"
                               Minimum="6" Maximum="80" Width="120" FormatString="F0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="每句最长时长(秒)" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding BatchMaxDuration, Mode=TwoWay}"
                               Minimum="1" Maximum="15" Width="120" FormatString="F1"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="停顿断句阈值(ms)" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding BatchPauseSplitMs, Mode=TwoWay}"
                               Minimum="100" Maximum="2000" Width="120" FormatString="F0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
