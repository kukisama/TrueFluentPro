<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrueFluentPro.ViewModels.Settings"
             xmlns:icons="https://github.com/projektanker/icons.avalonia"
             x:Class="TrueFluentPro.Views.Settings.TransferSection"
             x:DataType="vm:TransferSectionVM"
             x:CompileBindings="False">
        <Border Classes="app-card"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8" Padding="20">
        <StackPanel Spacing="12">
            <TextBlock Text="配置迁移" Theme="{StaticResource SubtitleTextBlockStyle}"/>
            <Separator/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button MinWidth="120"
                        Padding="16,8"
                        IsEnabled="{Binding !IsBusy}"
                        ToolTip.Tip="导出当前完整配置，包含主题、语言、录音、字幕、批处理、AI 与媒体等基础设置；不会包含 AAD 登录字段和 AAD 认证端点。"
                        Click="OnExportFullConfigClick">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <icons:Icon Value="fa-solid fa-box-archive" FontSize="12"/>
                        <TextBlock Text="导出完整配置" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button MinWidth="120"
                        Padding="16,8"
                        IsEnabled="{Binding !IsBusy}"
                        ToolTip.Tip="仅导出 Speech、存储、AI 终结点与模型选择等可迁移的基本 AI 配置；不会包含 AAD 登录字段、AAD 认证端点和个性化细项。"
                        Click="OnExportBasicAiConfigClick">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <icons:Icon Value="fa-solid fa-file-export" FontSize="12"/>
                        <TextBlock Text="导出基本AI配置" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button MinWidth="120"
                        Padding="16,8"
                        IsEnabled="{Binding !IsBusy}"
                        ToolTip.Tip="自动识别并导入“基本AI配置”或“完整配置”JSON；导入完整配置时会自动忽略 AAD 登录字段和 AAD 认证端点。"
                        Click="OnImportSettingsPackageClick">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <icons:Icon Value="fa-solid fa-file-import" FontSize="12"/>
                        <TextBlock Text="导入" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>