<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrueFluentPro.ViewModels.Settings"
             xmlns:controls="clr-namespace:TrueFluentPro.Controls"
             x:Class="TrueFluentPro.Views.Settings.InsightSection"
             x:DataType="vm:InsightSectionVM"
             x:CompileBindings="False">
        <Border Classes="app-card"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8" Padding="20">
        <StackPanel Spacing="12">
            <TextBlock Text="洞察" Theme="{StaticResource SubtitleTextBlockStyle}"/>
            <Separator/>

            <TextBlock Text="模型选择、总结思考和连通性测试已集中到“AI 资源与模型”。这里保留洞察提示词与快捷按钮配置。"
                       FontSize="11"
                       Foreground="Gray"
                       TextWrapping="Wrap"/>

            <Separator Margin="0,8,0,8"/>

            <TextBlock Text="系统提示词" FontWeight="SemiBold"/>
            <CheckBox Content="自动洞察一次性刷新（缓冲输出）" FontSize="11"
                      IsChecked="{Binding AutoInsightBufferOutput, Mode=TwoWay}"/>
            <StackPanel Spacing="4">
                <TextBlock Text="洞察系统提示词" FontSize="11" Foreground="Gray"/>
                <TextBox Text="{Binding InsightSystemPrompt, Mode=TwoWay}"
                         AcceptsReturn="True" Height="100" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="洞察用户内容模板" FontSize="11" Foreground="Gray"/>
                <TextBox Text="{Binding InsightUserContentTemplate, Mode=TwoWay}"
                         AcceptsReturn="True" Height="100" TextWrapping="Wrap"/>
                <TextBlock FontSize="10" Foreground="Gray" Text="占位符：{history} 翻译历史、{question} 用户问题"/>
            </StackPanel>

            <Separator Margin="0,8,0,8"/>
            <controls:PresetButtonsEditor Name="PresetButtonsEditorControl"
                                          Items="{Binding PresetButtons}"/>
        </StackPanel>
    </Border>
</UserControl>
