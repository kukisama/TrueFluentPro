<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrueFluentPro.ViewModels.Settings"
             x:Class="TrueFluentPro.Views.Settings.VideoGenSection"
             x:DataType="vm:VideoGenSectionVM"
             x:CompileBindings="False">
        <Border Classes="app-card"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8" Padding="20">
        <StackPanel Spacing="12">
            <TextBlock Text="视频生成" Theme="{StaticResource SubtitleTextBlockStyle}"/>
            <Separator/>

            <TextBlock Classes="field-note" TextWrapping="Wrap"
                       Text="视频模型已集中到 &quot;AI 资源与模型&quot;。这里保留视频生成默认参数与创作工坊运行参数。"/>

            <Separator Margin="0,8,0,8"/>
            <TextBlock Text="默认参数" FontWeight="Bold"/>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="API 模式:" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" MinWidth="220"
                          ItemsSource="{Binding VideoApiModeOptions}"
                          SelectedIndex="{Binding VideoApiModeIndex, Mode=TwoWay}">
                </ComboBox>
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Margin="0,0,0,2"
                           Classes="hint-text"
                           Text="{Binding SelectedVideoApiModeDescription}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="比例:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="2" Grid.Column="1" MinWidth="120"
                          ItemsSource="{Binding VideoAspectRatioOptions}"
                          SelectedItem="{Binding VideoAspectRatio, Mode=TwoWay}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="分辨率:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="3" Grid.Column="1" MinWidth="120"
                          ItemsSource="{Binding VideoResolutionOptions}"
                          SelectedItem="{Binding VideoResolution, Mode=TwoWay}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="默认时长(秒):" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="4" Grid.Column="1" MinWidth="120"
                          ItemsSource="{Binding VideoSecondsOptions}"
                          SelectedItem="{Binding VideoSeconds, Mode=TwoWay}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="默认数量:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="5" Grid.Column="1" MinWidth="120"
                          ItemsSource="{Binding VideoVariantsOptions}"
                          SelectedItem="{Binding VideoVariants, Mode=TwoWay}"/>
            </Grid>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="6" ColumnSpacing="8">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="目标像素:" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} x {1}">
                            <Binding Path="VideoWidth"/>
                            <Binding Path="VideoHeight"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="轮询间隔(ms):" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="1" Grid.Column="1"
                               Value="{Binding VideoPollIntervalMs, Mode=TwoWay}"
                               Minimum="500" Maximum="60000" Width="140" FormatString="F0"/>
            </Grid>

            <Separator Margin="0,8,0,8"/>
            <TextBlock Text="创作工坊运行参数" FontWeight="Bold"/>
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="6" ColumnSpacing="8">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="内存会话上限:" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="0" Grid.Column="1"
                               Value="{Binding MaxLoadedSessionsInMemory, Mode=TwoWay}"
                               Minimum="1" Maximum="64" Width="140" FormatString="F0"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="输出目录:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding MediaOutputDirectory, Mode=TwoWay}"
                         Watermark="留空使用会话默认目录"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
