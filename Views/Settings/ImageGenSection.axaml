<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrueFluentPro.ViewModels.Settings"
             xmlns:ctrl="using:TrueFluentPro.Controls"
             x:Class="TrueFluentPro.Views.Settings.ImageGenSection"
             x:DataType="vm:ImageGenSectionVM"
             x:CompileBindings="False">
        <Border Classes="app-card"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8" Padding="20">
        <StackPanel Spacing="12">
            <TextBlock Text="图片生成" Theme="{StaticResource SubtitleTextBlockStyle}"/>
            <Separator/>

            <TextBlock Classes="field-note" TextWrapping="Wrap"
                       Text="图片模型已集中到 &quot;AI 资源与模型&quot;。这里保留图片生成默认参数。"/>

            <Separator Margin="0,8,0,8"/>
            <TextBlock Text="默认参数" FontWeight="Bold"/>
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="尺寸:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="1" MinWidth="180"
                          ItemsSource="{Binding ImageSizeOptions}"
                          SelectedItem="{Binding ImageSize, Mode=TwoWay}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="质量:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="1" Grid.Column="1" MinWidth="180"
                          ItemsSource="{Binding ImageQualityOptions}"
                          SelectedItem="{Binding ImageQuality, Mode=TwoWay}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="格式:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="2" Grid.Column="1" MinWidth="180"
                          ItemsSource="{Binding ImageFormatOptions}"
                          SelectedItem="{Binding ImageFormat, Mode=TwoWay}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="数量:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="3" Grid.Column="1" MinWidth="120"
                          ItemsSource="{Binding ImageCountOptions}"
                          SelectedItem="{Binding ImageCount, Mode=TwoWay}"/>

                <!-- 改图模式已固定为 V2ResponsesApi（file_id + Responses API），不再向用户暴露选项 -->
            </Grid>

            <Separator Margin="0,8,0,8"/>
            <TextBlock Text="画布尺寸选择器" FontWeight="Bold"/>
            <TextBlock Classes="field-note" TextWrapping="Wrap"
                       Text="拖拽右下角手柄或点击画布自由选择图片尺寸（自动对齐 16px 网格）。选择结果会同步到上方尺寸下拉框。"/>
            <ctrl:ImageSizeCanvasSelector
                SelectedSize="{Binding ImageSize, Mode=TwoWay}"
                SelectedQuality="{Binding ImageQuality, Mode=OneWay}"
                Margin="0,4,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
