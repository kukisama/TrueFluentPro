<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrueFluentPro.ViewModels.Settings"
             x:Class="TrueFluentPro.Views.Settings.RecognitionSection"
             x:DataType="vm:RecognitionSectionVM"
             x:CompileBindings="False">
        <Border Classes="app-card"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8" Padding="20">
        <StackPanel Spacing="12">
            <TextBlock Text="语音识别" Theme="{StaticResource SubtitleTextBlockStyle}"/>
            <Separator/>

            <TextBlock Text="AI 语音模型（暂放这里，后续会拆出独立分区）" FontWeight="Bold"/>
            <TextBlock Classes="field-note" TextWrapping="Wrap" Text="从已配置的 AI 终结点里选择语音转写 / 文字转语音模型。当前批量与单文件 speech 字幕会优先使用这里的转写模型。"/>
            <StackPanel Spacing="5">
                <TextBlock Text="实时语音转写模型（预留给实时场景）"/>
                <ComboBox ItemsSource="{Binding SpeechToTextModels}"
                          SelectedItem="{Binding SelectedRealtimeTranscriptionModel, Mode=TwoWay}"
                          MinWidth="280"
                          HorizontalAlignment="Left"
                          IsEnabled="{Binding HasSpeechToTextModels}"/>
                <TextBlock Classes="hint-text" Text="当前主要先打通配置与单文件入口；实时流式语音场景后续再拆开。"
                           IsVisible="{Binding HasSpeechToTextModels}"/>
                <TextBlock Classes="hint-text" Text="还没有可用的语音转写模型，请先去 AI 终结点里把模型能力标成 &quot;语音转文字&quot;。"
                           IsVisible="{Binding !HasSpeechToTextModels}"/>
            </StackPanel>
            <StackPanel Spacing="5">
                <TextBlock Text="批量语音转写模型"/>
                <ComboBox ItemsSource="{Binding SpeechToTextModels}"
                          SelectedItem="{Binding SelectedBatchTranscriptionModel, Mode=TwoWay}"
                          MinWidth="280"
                          HorizontalAlignment="Left"
                          IsEnabled="{Binding HasSpeechToTextModels}"/>
                <TextBlock Classes="hint-text" Text="批量字幕与 speech 字幕生成会优先使用这里的模型；未配置时回退到现有 Azure Speech 批量/SDK 转写链路。"/>
            </StackPanel>
            <StackPanel Spacing="5">
                <TextBlock Text="文字转语音模型（预留）"/>
                <ComboBox ItemsSource="{Binding TextToSpeechModels}"
                          SelectedItem="{Binding SelectedTextToSpeechModel, Mode=TwoWay}"
                          MinWidth="280"
                          HorizontalAlignment="Left"
                          IsEnabled="{Binding HasTextToSpeechModels}"/>
                <TextBlock Classes="hint-text" Text="先把终结点与模型引用配置打通，运行时链路下一步再接。"/>
            </StackPanel>

            <TextBlock Text="识别策略" FontWeight="Bold"/>
            <CheckBox Content="过滤语气助词"
                      IsChecked="{Binding FilterModalParticles, Mode=TwoWay}"/>
            <StackPanel Spacing="5">
                <TextBlock Text="最大历史记录数量"/>
                <NumericUpDown Value="{Binding MaxHistoryItems, Mode=TwoWay}"
                               Minimum="5" Maximum="100" Width="120" FormatString="F0"
                               HorizontalAlignment="Left"/>
            </StackPanel>
            <StackPanel Spacing="5">
                <TextBlock Text="实时字幕最大长度"/>
                <NumericUpDown Value="{Binding RealtimeMaxLength, Mode=TwoWay}"
                               Minimum="50" Maximum="500" Width="120" FormatString="F0"
                               HorizontalAlignment="Left"/>
            </StackPanel>
            <StackPanel Spacing="5">
                <TextBlock Text="Chunk 时长 (ms)"/>
                <NumericUpDown Value="{Binding ChunkDurationMs, Mode=TwoWay}"
                               Minimum="20" Maximum="2000" Width="120" FormatString="F0"
                               HorizontalAlignment="Left"/>
                <TextBlock Classes="caption-text" Text="默认 200ms；可改为 500ms（延迟更高）"/>
            </StackPanel>

            <Separator Margin="0,8,0,8"/>
            <TextBlock Text="静音超时" FontWeight="Bold"/>
            <CheckBox Content="启用静音超时"
                      IsChecked="{Binding EnableAutoTimeout, Mode=TwoWay}"/>
            <StackPanel Spacing="5">
                <TextBlock Text="初始静音超时 (秒)"/>
                <NumericUpDown Value="{Binding InitialSilenceTimeoutSeconds, Mode=TwoWay}"
                               Minimum="1" Maximum="300" Width="120" FormatString="F0"
                               HorizontalAlignment="Left"
                               IsEnabled="{Binding EnableAutoTimeout}"/>
            </StackPanel>
            <StackPanel Spacing="5">
                <TextBlock Text="断句静音超时 (秒)"/>
                <NumericUpDown Value="{Binding EndSilenceTimeoutSeconds, Mode=TwoWay}"
                               Minimum="1" Maximum="30" Width="120" FormatString="F0"
                               HorizontalAlignment="Left"
                               IsEnabled="{Binding EnableAutoTimeout}"/>
            </StackPanel>

            <Separator Margin="0,8,0,8"/>
            <TextBlock Text="无回显重连" FontWeight="Bold"/>
            <CheckBox Content="有音频输入但无回显时自动重连"
                      IsChecked="{Binding EnableNoResponseRestart, Mode=TwoWay}"/>
            <StackPanel Spacing="5">
                <TextBlock Text="无回显阈值 (秒)"/>
                <NumericUpDown Value="{Binding NoResponseRestartSeconds, Mode=TwoWay}"
                               Minimum="1" Maximum="30" Width="120" FormatString="F0"
                               HorizontalAlignment="Left"
                               IsEnabled="{Binding EnableNoResponseRestart}"/>
            </StackPanel>
            <StackPanel Spacing="5">
                <TextBlock Text="音频活动阈值"/>
                <NumericUpDown Value="{Binding AudioActivityThreshold, Mode=TwoWay}"
                               Minimum="50" Maximum="8000" Width="120" FormatString="F0"
                               HorizontalAlignment="Left"
                               IsEnabled="{Binding EnableNoResponseRestart}"/>
            </StackPanel>
            <StackPanel Spacing="5">
                <TextBlock Text="电平显示放大倍数"/>
                <NumericUpDown Value="{Binding AudioLevelGain, Mode=TwoWay}"
                               Minimum="0.5" Maximum="10" Width="120" FormatString="F1"
                               HorizontalAlignment="Left"/>
            </StackPanel>
            <StackPanel Spacing="5">
                <TextBlock Text="自动增益预设"/>
                <ComboBox MinWidth="140"
                          HorizontalAlignment="Left"
                          SelectedIndex="{Binding AutoGainPresetIndex, Mode=TwoWay}">
                    <ComboBoxItem Content="关闭"/>
                    <ComboBoxItem Content="低"/>
                    <ComboBoxItem Content="中"/>
                    <ComboBoxItem Content="高"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="5" Margin="0,8,0,0">
                <TextBlock Text="音频预处理插件" FontWeight="SemiBold"/>
                <TextBlock Text="主处理链路插在采集之后、录音/识别之前。录音和识别会共用同一份处理后音频。"
                           FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
                <ComboBox MinWidth="220"
                          HorizontalAlignment="Left"
                          SelectedIndex="{Binding AudioPreProcessorPluginIndex, Mode=TwoWay}">
                    <ComboBoxItem Content="关闭"/>
                    <ComboBoxItem Content="WebRTC APM（主线）"/>
                </ComboBox>
            </StackPanel>

            <Border Margin="0,8,0,0" Padding="12"
                    Background="{DynamicResource LayerFillColorDefaultBrush}"
                    CornerRadius="6"
                    IsVisible="{Binding IsWebRtcPluginSelected}">
                <StackPanel Spacing="8">
                    <TextBlock Text="WebRTC APM 参数" FontWeight="SemiBold"/>
                    <TextBlock Text="状态说明会告诉你当前参数下插件能否在本机初始化；“检测 WebRTC 插件”只做本地加载/初始化检查，不会启动真实录音。"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="检测 WebRTC 插件"
                        Command="{Binding TestWebRtcPluginCommand}"
                        HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding WebRtcPluginStatus}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="520"/>
                    </StackPanel>
                    <CheckBox Content="回声消除 (AEC)" IsChecked="{Binding WebRtcAecEnabled, Mode=TwoWay}"/>
                    <CheckBox Content="移动端 AEC 模式" IsChecked="{Binding WebRtcAecMobileMode, Mode=TwoWay}"
                              IsEnabled="{Binding WebRtcAecEnabled}" Margin="20,0,0,0"/>
                    <StackPanel Spacing="5">
                        <TextBlock Text="AEC 延迟估计 (ms)"/>
                        <NumericUpDown Value="{Binding WebRtcAecLatencyMs, Mode=TwoWay}"
                                       Minimum="0" Maximum="500" Width="120" FormatString="F0"
                                       HorizontalAlignment="Left"
                                       IsEnabled="{Binding WebRtcAecEnabled}"/>
                    </StackPanel>

                    <CheckBox Content="降噪 (NS)" IsChecked="{Binding WebRtcNoiseSuppressionEnabled, Mode=TwoWay}"/>
                    <StackPanel Spacing="5">
                        <TextBlock Text="降噪等级"/>
                        <ComboBox MinWidth="160"
                                  HorizontalAlignment="Left"
                                  SelectedIndex="{Binding WebRtcNoiseSuppressionLevel, Mode=TwoWay}"
                                  IsEnabled="{Binding WebRtcNoiseSuppressionEnabled}">
                            <ComboBoxItem Content="低"/>
                            <ComboBoxItem Content="中"/>
                            <ComboBoxItem Content="高"/>
                            <ComboBoxItem Content="很高"/>
                        </ComboBox>
                    </StackPanel>

                    <CheckBox Content="AGC1 自动增益" IsChecked="{Binding WebRtcAgc1Enabled, Mode=TwoWay}"/>
                    <CheckBox Content="AGC2 自动增益" IsChecked="{Binding WebRtcAgc2Enabled, Mode=TwoWay}"/>
                    <StackPanel Spacing="5">
                        <TextBlock Text="AGC 模式"/>
                        <ComboBox MinWidth="180"
                                  HorizontalAlignment="Left"
                                  SelectedIndex="{Binding WebRtcAgcMode, Mode=TwoWay}">
                            <ComboBoxItem Content="AdaptiveAnalog"/>
                            <ComboBoxItem Content="AdaptiveDigital"/>
                            <ComboBoxItem Content="FixedDigital"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel Spacing="5">
                            <TextBlock Text="目标电平 (dBFS)"/>
                            <NumericUpDown Value="{Binding WebRtcAgcTargetLevelDbfs, Mode=TwoWay}"
                                           Minimum="-31" Maximum="0" Width="120" FormatString="F0"
                                           HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="5">
                            <TextBlock Text="压缩增益 (dB)"/>
                            <NumericUpDown Value="{Binding WebRtcAgcCompressionGainDb, Mode=TwoWay}"
                                           Minimum="0" Maximum="90" Width="120" FormatString="F0"
                                           HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                    <CheckBox Content="AGC Limiter" IsChecked="{Binding WebRtcAgcLimiterEnabled, Mode=TwoWay}"/>
                    <CheckBox Content="高通滤波 (HPF)" IsChecked="{Binding WebRtcHighPassFilterEnabled, Mode=TwoWay}"/>
                    <CheckBox Content="前置放大" IsChecked="{Binding WebRtcPreAmpEnabled, Mode=TwoWay}"/>
                    <StackPanel Spacing="5">
                        <TextBlock Text="前置放大倍数"/>
                        <NumericUpDown Value="{Binding WebRtcPreAmpGain, Mode=TwoWay}"
                                       Minimum="0.5" Maximum="8" Width="120" FormatString="F1"
                                       HorizontalAlignment="Left"
                                       IsEnabled="{Binding WebRtcPreAmpEnabled}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Microsoft Audio Stack (MAS) 识别增强 -->
            <StackPanel Spacing="5" Margin="0,8,0,0">
                <TextBlock Text="Microsoft 音频处理 (MAS) 云端识别增强" FontWeight="SemiBold"/>
                <TextBlock Text="该选项仅增强云端识别支路，不会替代应用层主插件。适合在主插件处理后，额外给 Speech SDK 做降噪/去混响增强。"
                           FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
                <CheckBox Content="启用 MAS 识别增强"
                          IsChecked="{Binding EnableMasAudioProcessing, Mode=TwoWay}"/>
                <CheckBox Content="回声消除 (AEC)"
                          IsChecked="{Binding MasEchoCancellationEnabled, Mode=TwoWay}"
                          IsEnabled="{Binding EnableMasAudioProcessing}"
                          Margin="20,0,0,0"/>
                <CheckBox Content="降噪 (NS)"
                          IsChecked="{Binding MasNoiseSuppressionEnabled, Mode=TwoWay}"
                          IsEnabled="{Binding EnableMasAudioProcessing}"
                          Margin="20,0,0,0"/>
            </StackPanel>

            <!-- VAD 门控（双路说话人分离） -->
            <StackPanel Spacing="5" Margin="0,8,0,0">
                <TextBlock Text="VAD 门控（双路说话人分离）" FontWeight="SemiBold"/>
                <TextBlock Text="环回+麦克风双路模式下，自动识别谁在说话并切源。谁先开口整句归谁，被打断后自动切换。需重启翻译生效。"
                           FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
                <CheckBox Content="启用 VAD 门控"
                          IsChecked="{Binding EnableVadGating, Mode=TwoWay}"/>
                <StackPanel Spacing="5" IsEnabled="{Binding EnableVadGating}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel Spacing="5">
                            <TextBlock Text="语音检测阈值 (RMS)"/>
                            <NumericUpDown Value="{Binding VadVoiceThreshold, Mode=TwoWay}"
                                           Minimum="0.001" Maximum="0.5" Width="120" FormatString="F3"
                                           Increment="0.005"
                                           HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="5">
                            <TextBlock Text="打断判定 (chunk 数)"/>
                            <NumericUpDown Value="{Binding VadInterruptionChunks, Mode=TwoWay}"
                                           Minimum="1" Maximum="50" Width="120" FormatString="F0"
                                           HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="5">
                            <TextBlock Text="安全阀 (chunk 数)"/>
                            <NumericUpDown Value="{Binding VadSafetyValveChunks, Mode=TwoWay}"
                                           Minimum="5" Maximum="100" Width="120" FormatString="F0"
                                           HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <TextBlock Text="同时开口时优先"/>
                        <ComboBox MinWidth="160"
                                  HorizontalAlignment="Left"
                                  SelectedIndex="{Binding VadConflictPriority, Mode=TwoWay}">
                            <ComboBoxItem Content="对方 (环回)"/>
                            <ComboBoxItem Content="我 (麦克风)"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <CheckBox Content="在字幕中显示 *触发重连* 提示"
                      IsChecked="{Binding ShowReconnectMarker, Mode=TwoWay}"
                      IsEnabled="{Binding EnableNoResponseRestart}"/>
        </StackPanel>
    </Border>
</UserControl>
