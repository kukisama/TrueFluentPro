<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrueFluentPro.ViewModels"
             x:Class="TrueFluentPro.Views.Settings.AudioSection"
             x:DataType="vm:AudioDevicesViewModel"
             x:CompileBindings="False">
    <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8" Padding="20">
        <StackPanel Spacing="12">
            <TextBlock Text="音频设备" Theme="{StaticResource SubtitleTextBlockStyle}"/>
            <Separator/>
            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="麦克风:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="1" MinWidth="220"
                          ItemsSource="{Binding AudioDevicesList}"
                          SelectedItem="{Binding SelectedAudioDevice, Mode=TwoWay}"
                          IsEnabled="{Binding IsInputDeviceUiEnabled}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="系统回环:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="1" Grid.Column="1" MinWidth="220"
                          ItemsSource="{Binding OutputDevicesList}"
                          SelectedItem="{Binding SelectedOutputDevice, Mode=TwoWay}"
                          IsEnabled="{Binding IsOutputDeviceUiEnabled}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="录制来源:" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <ToggleButton Content="仅环回"
                                  IsChecked="{Binding IsRecordingLoopbackOnly, Mode=TwoWay}"/>
                    <ToggleButton Content="环回+麦克风"
                                  IsChecked="{Binding IsRecordingLoopbackMix, Mode=TwoWay}"/>
                    <ToggleButton Content="仅麦克风"
                                  IsChecked="{Binding IsRecordingMicOnly, Mode=TwoWay}"/>
                </StackPanel>

                <Button Grid.Row="0" Grid.Column="2" Content="刷新" Padding="8,4"
                        Command="{Binding RefreshAudioDevicesCommand}"
                        IsEnabled="{Binding IsAudioDeviceRefreshEnabled}"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
