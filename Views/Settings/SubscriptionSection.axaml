<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrueFluentPro.ViewModels.Settings"
             xmlns:models="using:TrueFluentPro.Models"
             xmlns:views="clr-namespace:TrueFluentPro.Views"
             x:Class="TrueFluentPro.Views.Settings.SubscriptionSection"
             x:DataType="vm:SubscriptionSectionVM"
             x:CompileBindings="False">
    <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,0">
        <StackPanel Spacing="12">
            <TextBlock Text="Azure Speech" Theme="{StaticResource SubtitleTextBlockStyle}"/>
            <Separator/>
            <TextBlock Text="管理 Azure 语音服务订阅" Foreground="Gray" FontSize="12"/>

            <!-- 当前订阅选择 (仍绑定 ConfigVM) -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="当前订阅:" VerticalAlignment="Center"/>
                <ComboBox MinWidth="200"
                          ItemsSource="{Binding $parent[views:SettingsView].DataContext.ConfigVM.SubscriptionNames}"
                          SelectedIndex="{Binding $parent[views:SettingsView].DataContext.ConfigVM.ActiveSubscriptionIndex, Mode=TwoWay}"
                          IsEnabled="{Binding $parent[views:SettingsView].DataContext.ConfigVM.IsConfigurationEnabled}"/>
                <Ellipse Width="12" Height="12" StrokeThickness="2"
                         VerticalAlignment="Center" Margin="4,0"
                         Fill="{Binding $parent[views:SettingsView].DataContext.ConfigVM.SubscriptionLampFill}"
                         Stroke="{Binding $parent[views:SettingsView].DataContext.ConfigVM.SubscriptionLampStroke}"
                         Opacity="{Binding $parent[views:SettingsView].DataContext.ConfigVM.SubscriptionLampOpacity}"
                         ToolTip.Tip="{Binding $parent[views:SettingsView].DataContext.ConfigVM.SubscriptionValidationStatusMessage}"/>
            </StackPanel>

            <!-- 订阅 CRUD -->
            <Grid ColumnDefinitions="190,*" ColumnSpacing="12">
                <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="0,0,4,0">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Text="订阅列表" FontWeight="Bold" Margin="10,10,10,5"/>
                        <ListBox Grid.Row="1" Name="SubscriptionListBox" Margin="10"
                                 MinHeight="120"
                                 ItemsSource="{Binding Subscriptions}"
                                 SelectedItem="{Binding SelectedSubscription, Mode=TwoWay}"
                                 SelectionMode="Single">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="models:AzureSubscription">
                                    <StackPanel Orientation="Vertical" Margin="5">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding ServiceRegion}" FontSize="12" Foreground="Gray"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Spacing="10" HorizontalAlignment="Left">
                    <TextBlock Text="订阅配置" FontWeight="Bold"/>
                    <StackPanel Spacing="5">
                        <TextBlock Text="订阅名称"/>
                        <TextBox Text="{Binding SubscriptionEditorName, Mode=TwoWay}"
                                 Watermark="例如：生产环境、测试环境"
                                 Width="420"
                                 MaxWidth="420"
                                 HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <TextBlock Text="订阅密钥"/>
                        <TextBox Text="{Binding SubscriptionEditorKey, Mode=TwoWay}"
                                 Watermark="输入 Azure 语音服务订阅密钥"
                                 MaxWidth="420" Width="420"
                                 HorizontalAlignment="Left"
                                 PasswordChar="*"
                                 RevealPassword="{Binding IsChecked, ElementName=SubShowPwdCheckBox}"/>
                        <CheckBox Name="SubShowPwdCheckBox" Content="显示密钥" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <TextBlock Text="终结点"/>
                        <TextBox Text="{Binding SubscriptionEditorEndpoint, Mode=TwoWay}"
                                 Watermark="例如: https://southeastasia.api.cognitive.microsoft.com/"
                                 MaxWidth="420" Width="420"
                                 HorizontalAlignment="Left"/>
                        <TextBlock FontSize="10" Foreground="Gray"
                                   Text="国际版: https://{区域}.api.cognitive.microsoft.com/&#x0a;中国版: https://{区域}.api.cognitive.azure.cn/"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SubscriptionEditorRegionHint}"
                                   FontSize="10" Foreground="DarkGreen" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,10,0,0" HorizontalAlignment="Left">
                        <Button Content="添加" Width="60" Command="{Binding AddSubscriptionCommand}"/>
                        <Button Content="更新" Width="60" Command="{Binding UpdateSubscriptionCommand}"/>
                        <Button Content="删除" Width="60" Command="{Binding DeleteSubscriptionCommand}"/>
                        <Button Content="测试" Width="60" Command="{Binding TestSubscriptionCommand}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SubscriptionMessage}" FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>

                    <Separator Margin="0,8,0,4"/>
                    <Button Content="全部测试速度" Padding="12,6" Command="{Binding TestAllSubscriptionsCommand}" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding TestAllResult}" FontSize="11" Foreground="Gray"
                               TextWrapping="Wrap" IsVisible="{Binding ShowTestAllResult}"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
