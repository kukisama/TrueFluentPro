<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TrueFluentPro.ViewModels.Settings"
             xmlns:models="using:TrueFluentPro.Models"
             xmlns:views="clr-namespace:TrueFluentPro.Views"
             xmlns:icons="https://github.com/projektanker/icons.avalonia"
             x:Class="TrueFluentPro.Views.Settings.SubscriptionSection"
             x:DataType="vm:SubscriptionSectionVM"
             x:CompileBindings="False">
        <Border Classes="app-card"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,0">
        <StackPanel Spacing="12">
            <TextBlock Text="Azure Speech" Theme="{StaticResource SubtitleTextBlockStyle}"/>
            <Separator/>
            <TextBlock Text="管理 Azure 语音服务订阅" Classes="section-description"/>

            <!-- 订阅 CRUD -->
            <Grid ColumnDefinitions="190,*" ColumnSpacing="12">
                <Border Grid.Column="0" Classes="sub-card" BorderBrush="{DynamicResource SubCardBorderBrush}" BorderThickness="1" Margin="0,0,4,0">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Text="订阅列表" FontWeight="Bold" Margin="10,10,10,5"/>
                        <ListBox Grid.Row="1" Name="SubscriptionListBox" Margin="10"
                                 MinHeight="120"
                                 ItemsSource="{Binding Subscriptions}"
                                 SelectedItem="{Binding SelectedSubscription, Mode=TwoWay}"
                                 SelectionMode="Single">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="models:AzureSubscription">
                                    <StackPanel Orientation="Vertical" Margin="5">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                        <TextBlock Classes="section-description" Text="{Binding ServiceRegion}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Spacing="10" HorizontalAlignment="Left">
                    <TextBlock Text="订阅配置" FontWeight="Bold"/>
                    <StackPanel Spacing="5">
                        <TextBlock Text="订阅名称"/>
                        <TextBox Text="{Binding SubscriptionEditorName, Mode=TwoWay}"
                                 Watermark="例如：生产环境、测试环境"
                                 Width="420"
                                 MaxWidth="420"
                                 HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <TextBlock Text="订阅密钥"/>
                        <Grid ColumnDefinitions="420,Auto" ColumnSpacing="8" HorizontalAlignment="Left">
                            <TextBox Grid.Column="0"
                                     Text="{Binding SubscriptionEditorKey, Mode=TwoWay}"
                                     Watermark="输入 Azure 语音服务订阅密钥"
                                     MaxWidth="420" Width="420"
                                     HorizontalAlignment="Left"
                                     PasswordChar="*"/>
                            <Button Grid.Column="1"
                                    Width="36"
                                    Height="32"
                                    ToolTip.Tip="复制密钥"
                                    Click="CopySubscriptionKey_Click">
                                <icons:Icon Value="fa-regular fa-copy" FontSize="13"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <TextBlock Text="终结点"/>
                        <TextBox Text="{Binding SubscriptionEditorEndpoint, Mode=TwoWay}"
                                 Watermark="例如: https://southeastasia.api.cognitive.microsoft.com/"
                                 MaxWidth="420" Width="420"
                                 HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding SubscriptionEditorRegionHint}"
                                   FontSize="10" Foreground="{DynamicResource SuccessBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,4,0,0" HorizontalAlignment="Left">
                        <Button Width="88" Height="32" Command="{Binding AddSubscriptionCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <icons:Icon Value="fa-solid fa-plus" FontSize="12"/>
                                <TextBlock Text="添加" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Width="88" Height="32" Command="{Binding UpdateSubscriptionCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <icons:Icon Value="fa-solid fa-pen" FontSize="12"/>
                                <TextBlock Text="更新" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Width="88" Height="32" Command="{Binding DeleteSubscriptionCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <icons:Icon Value="fa-solid fa-trash" FontSize="12"/>
                                <TextBlock Text="删除" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Width="88" Height="32" Command="{Binding TestSubscriptionCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <icons:Icon Value="fa-solid fa-check" FontSize="12"/>
                                <TextBlock Text="测试" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Width="108" Height="32" Command="{Binding TestAllSubscriptionsCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <icons:Icon Value="fa-solid fa-check-double" FontSize="12"/>
                                <TextBlock Text="测试全部" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock Classes="field-note" Text="{Binding SubscriptionMessage}" TextWrapping="Wrap"
                               Margin="0,4,0,0"/>

                    <TextBlock Classes="field-note" Text="{Binding TestAllResult}" Margin="0,2,0,0"
                               TextWrapping="Wrap" IsVisible="{Binding ShowTestAllResult}"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
