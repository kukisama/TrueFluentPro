<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:TrueFluentPro.Controls"
             xmlns:icons="https://github.com/projektanker/icons.avalonia"
             xmlns:vm="using:TrueFluentPro.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1460"
             d:DesignHeight="900"
             x:Class="TrueFluentPro.Views.MediaCenterV2View"
             x:DataType="vm:MediaCenterV2ViewModel"
             x:CompileBindings="False">

    <UserControl.Resources>
        <controls:FilePathToBitmapConverter x:Key="FilePathToBitmapConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="RadioButton.creator-pill">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Background" Value="{DynamicResource MediaItemBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="RadioButton.creator-pill:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        </Style>
        <Style Selector="RadioButton.creator-pill:checked">
            <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="RadioButton.creator-pill:checked TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="RadioButton.creator-pill:checked icons|Icon">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.rail-thumb">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.workspace-tab-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style Selector="TextBlock.panel-title">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.panel-note">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}"/>
        </Style>
        <Style Selector="TextBlock.meta-label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="Border.mode-accent-card">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
        <Style Selector="Border.selection-outline">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style Selector="Border.pending-placeholder">
            <Setter Property="Background" Value="{DynamicResource PendingPlaceholderBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PendingPlaceholderBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="INFINITE">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Opacity" Value="0.42"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <Grid Background="{DynamicResource PageBackgroundBrush}"
          RowDefinitions="*,Auto"
            ColumnDefinitions="264,12,*,12,140">

        <Border Grid.RowSpan="2" Grid.Column="0" Classes="app-card" Margin="12,12,0,12" Padding="14,14,8,14" ClipToBounds="True">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,4,0">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Classes="panel-title" Text="{Binding WorkspaceName}"/>
                            <TextBlock Classes="panel-note" Text="{Binding WorkspaceSubtitle}" TextWrapping="Wrap"/>
                            <TextBlock Classes="panel-note"
                                       Foreground="{DynamicResource AccentBlueBrush}"
                                       Text="{Binding WorkspaceLineageText}"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding HasWorkspaceLineage}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding NewWorkspaceCommand}"
                                ToolTip.Tip="新建一张空白画布"
                                AutomationProperties.Name="新建画布"
                                Width="36"
                                Height="36"
                                CornerRadius="18">
                            <icons:Icon Value="fa-solid fa-plus" FontSize="14"/>
                        </Button>
                    </Grid>

                    <Border Classes="sub-card" Padding="12">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" FontSize="13" FontWeight="SemiBold" Text="运行参数"/>
                                <Border Grid.Column="1"
                                        Background="{Binding ModeAccentBackground}"
                                        BorderBrush="{Binding ModeAccentBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="999"
                                        Padding="8,3">
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding CurrentCanvasTitle}"/>
                                </Border>
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Border Grid.Column="0" Background="{DynamicResource MediaItemBrush}" CornerRadius="10" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Classes="meta-label" Text="提供商"/>
                                        <TextBlock FontWeight="SemiBold" FontSize="12" Text="{Binding CurrentEndpointDisplayName}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="{DynamicResource MediaItemBrush}" CornerRadius="10" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Classes="meta-label" Text="模型"/>
                                        <TextBlock FontWeight="SemiBold" FontSize="12" Text="{Binding CurrentModelDisplayName}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel Spacing="8" IsVisible="{Binding IsImageKind}">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="尺寸"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1"
                                              ItemsSource="{Binding WorkspaceSession.ImageSizeOptions}"
                                              SelectedItem="{Binding WorkspaceSession.ImageSize}"
                                              Padding="8,5"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="质量"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1"
                                              ItemsSource="{Binding WorkspaceSession.ImageQualityOptions}"
                                              SelectedItem="{Binding WorkspaceSession.ImageQuality}"
                                              Padding="8,5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="格式"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1"
                                              ItemsSource="{Binding WorkspaceSession.ImageFormatOptions}"
                                              SelectedItem="{Binding WorkspaceSession.ImageFormat}"
                                              Padding="8,5"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="数量"/>
                                    <ComboBox Grid.Row="3" Grid.Column="1"
                                              ItemsSource="{Binding WorkspaceSession.ImageCountOptions}"
                                              SelectedItem="{Binding WorkspaceSession.ImageCount}"
                                              Padding="8,5"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8" IsVisible="{Binding IsVideoKind}">

                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="比例"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1"
                                              ItemsSource="{Binding WorkspaceSession.VideoAspectRatioOptions}"
                                              SelectedItem="{Binding WorkspaceSession.VideoAspectRatio}"
                                              Padding="8,5"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="分辨率"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1"
                                              ItemsSource="{Binding WorkspaceSession.VideoResolutionOptions}"
                                              SelectedItem="{Binding WorkspaceSession.VideoResolution}"
                                              Padding="8,5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="时长"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1"
                                              ItemsSource="{Binding WorkspaceSession.VideoDurationOptions}"
                                              SelectedItem="{Binding WorkspaceSession.VideoSeconds}"
                                              Padding="8,5"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="数量"/>
                                    <ComboBox Grid.Row="3" Grid.Column="1"
                                              ItemsSource="{Binding WorkspaceSession.VideoCountOptions}"
                                              SelectedItem="{Binding WorkspaceSession.VideoVariants}"
                                              Padding="8,5"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Classes="sub-card mode-accent-card"
                            Padding="12"
                            IsVisible="{Binding IsReferencePanelVisible}"
                            Background="{Binding ModeAccentBackground}"
                            BorderBrush="{Binding ModeAccentBorderBrush}">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="参考素材"/>
                                    <TextBlock Classes="panel-note" Text="{Binding ReferenceSummaryText}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Width="34" Height="34"
                                        CornerRadius="17"
                                        Click="AttachReferenceImage_Click"
                                        IsVisible="{Binding CanAttachReferenceImages}"
                                        AutomationProperties.Name="添加参考图"
                                        ToolTip.Tip="添加参考图">
                                    <icons:Icon Value="fa-solid fa-plus" FontSize="12"/>
                                </Button>
                            </Grid>

                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding WorkspaceSession.ReferenceImagePaths}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Width="56" Height="56">
                                                <Border CornerRadius="8"
                                                        Background="{DynamicResource MediaItemBrush}"
                                                        BorderBrush="{DynamicResource ThumbnailBorderBrush}"
                                                        BorderThickness="1"
                                                        Cursor="Hand"
                                                        PointerPressed="ReferenceImageThumbnail_PointerPressed"
                                                        ToolTip.Tip="视频模式下点击可裁切到目标尺寸">
                                                    <controls:ViewportLazyImage FilePath="{Binding .}"
                                                                                Stretch="UniformToFill"
                                                                                HorizontalAlignment="Stretch"
                                                                                VerticalAlignment="Stretch"/>
                                                </Border>
                                                <Button Width="18"
                                                        Height="18"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Margin="0,-4,-4,0"
                                                        Padding="0"
                                                        CornerRadius="9"
                                                        Command="{Binding DataContext.WorkspaceSession.RemoveReferenceImageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding .}"
                                                        ToolTip.Tip="删除参考图">
                                                    <icons:Icon Value="fa-solid fa-xmark" FontSize="10"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border Classes="sub-card mode-accent-card"
                            Padding="12"
                            Background="{Binding ModeAccentBackground}"
                            BorderBrush="{Binding ModeAccentBorderBrush}">
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" FontSize="13" FontWeight="SemiBold" Text="创作类型"/>
                                <Border Grid.Column="1"
                                        Background="#1AFFFFFF"
                                        CornerRadius="999"
                                        Padding="8,3">
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding CurrentModeBadgeText}"/>
                                </Border>
                            </Grid>
                            <WrapPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <RadioButton Classes="creator-pill" GroupName="MediaKind" IsChecked="{Binding IsImageKind}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <icons:Icon Value="fa-regular fa-image" FontSize="12"/>
                                        <TextBlock Text="图片"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Classes="creator-pill" GroupName="MediaKind" IsChecked="{Binding IsVideoKind}" Margin="8,0,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <icons:Icon Value="fa-solid fa-film" FontSize="12"/>
                                        <TextBlock Text="视频"/>
                                    </StackPanel>
                                </RadioButton>
                            </WrapPanel>
                            <TextBlock Classes="panel-note"
                                       Text="上传参考图后会自动进入对应的参考图流程，无需再手动切换“新建 / 编辑”。"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <GridSplitter Grid.RowSpan="2" Grid.Column="1"
                      Width="12"
                  Margin="0,12,0,12"
                      Background="Transparent"
                      ResizeDirection="Columns"
                      ShowsPreview="True"/>

        <Border Grid.Row="0" Grid.Column="2" Classes="app-card" Margin="0,12,0,10" Padding="18,16">
            <Grid RowDefinitions="Auto,14,*,14,Auto">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Classes="panel-title" Text="{Binding CurrentCanvasTitle}"/>
                        <TextBlock Classes="panel-note" Text="{Binding CurrentCanvasDescription}" TextWrapping="Wrap"/>
                        <TextBlock Classes="panel-note"
                                   Foreground="{DynamicResource AccentBlueBrush}"
                                   Text="{Binding WorkspaceLineageText}"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding HasWorkspaceLineage}"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Padding="12,8"
                            CornerRadius="8"
                            Command="{Binding OpenWorkspaceFolderCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <icons:Icon Value="fa-regular fa-folder-open" FontSize="13"/>
                            <TextBlock Text="打开画布目录"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Border Grid.Row="2"
                        Background="{Binding ModeAccentBackground}"
                        BorderBrush="{Binding ModeAccentBorderBrush}"
                        BorderThickness="1.5"
                    CornerRadius="18">
                    <Grid>
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="10"
                                    IsVisible="{Binding HasNoCanvasPreview}">
                            <icons:Icon Value="fa-regular fa-images" FontSize="52" Foreground="{DynamicResource TextPlaceholderBrush}"/>
                            <TextBlock FontSize="18" Foreground="{DynamicResource TextPlaceholderBrush}" Text="{Binding CanvasPlaceholderTitle}"/>
                            <TextBlock Classes="panel-note"
                                       Width="320"
                                       TextAlignment="Center"
                                       Text="{Binding CanvasPlaceholderDescription}"/>
                        </StackPanel>

                        <!-- 资产预览：图片和视频首帧均全画布显示 -->
                        <controls:ViewportLazyImage FilePath="{Binding CanvasPreviewPath}"
                                                    Stretch="Uniform"
                                                    Margin="18"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    PointerPressed="PreviewSurface_PointerPressed"
                                                    IsVisible="{Binding HasCanvasPreview}"/>

                        <!-- 视频播放按钮：居中覆盖，点击用系统播放器打开 -->
                        <Button HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="64" Height="64"
                                CornerRadius="32"
                                Background="#CC000000"
                                Foreground="White"
                                Opacity="0.85"
                                Cursor="Hand"
                                Click="PlayVideoButton_Click"
                                AutomationProperties.Name="播放视频"
                                IsVisible="{Binding IsCanvasPreviewVideo}">
                            <icons:Icon Value="fa-solid fa-play" FontSize="24" Margin="4,0,0,0"/>
                        </Button>

                        <!-- 元信息标签（左上角） -->
                        <Border HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="18"
                                Background="#AA000000"
                                CornerRadius="999"
                                Padding="8,4"
                                IsHitTestVisible="False"
                                IsVisible="{Binding HasCanvasPreview}">
                            <TextBlock FontSize="11" Foreground="White" Text="{Binding CanvasPreviewMetaText}"/>
                        </Border>

                        <Button HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="20,0,0,0"
                                Width="40" Height="40"
                                CornerRadius="20"
                                AutomationProperties.Name="上一张"
                                PointerPressed="PreviewNavButton_PointerPressed"
                                Command="{Binding SelectPreviousAssetCommand}"
                                IsEnabled="{Binding CanSelectPreviousAsset}">
                            <icons:Icon Value="fa-solid fa-chevron-left" FontSize="14"/>
                        </Button>
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,20,0"
                                Width="40" Height="40"
                                CornerRadius="20"
                                AutomationProperties.Name="下一张"
                                PointerPressed="PreviewNavButton_PointerPressed"
                                Command="{Binding SelectNextAssetCommand}"
                                IsEnabled="{Binding CanSelectNextAsset}">
                            <icons:Icon Value="fa-solid fa-chevron-right" FontSize="14"/>
                        </Button>

                        <Border HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,14"
                                Background="#99000000"
                                CornerRadius="999"
                                Padding="10,4"
                                IsHitTestVisible="False"
                                IsVisible="{Binding HasSelectedAsset}">
                            <TextBlock FontSize="12" Foreground="White" Text="{Binding SelectedAssetCounterText}"/>
                        </Border>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="4" Spacing="10">
                    <StackPanel Spacing="2">
                        <Border HorizontalAlignment="Left"
                                Background="{Binding ModeAccentBackground}"
                                BorderBrush="{Binding ModeAccentBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="8,3">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding SelectedGroupWorkflowText}"/>
                        </Border>
                        <SelectableTextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding SelectedGroupPromptText}" TextWrapping="Wrap"/>
                        <TextBlock Classes="panel-note" Text="{Binding SelectedGroupMetaText}"/>
                    </StackPanel>

                    <SelectableTextBlock Classes="panel-note" Text="{Binding SelectedGroupSuggestedNextText}" TextWrapping="Wrap"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding SelectedGroup.Items}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Classes="rail-thumb"
                                            Command="{Binding DataContext.SelectAssetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            PointerReleased="RailThumbButton_PointerReleased">
                                        <Border Width="92"
                                                Height="72"
                                                Background="{DynamicResource MediaItemBrush}"
                                                CornerRadius="10"
                                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Border Classes="pending-placeholder"
                                                        CornerRadius="10"
                                                        Margin="0"
                                                        IsVisible="{Binding IsPending}">
                                                    <StackPanel VerticalAlignment="Center"
                                                                HorizontalAlignment="Center"
                                                                Spacing="4">
                                                        <icons:Icon Value="fa-solid fa-wand-magic-sparkles" FontSize="15" Foreground="{DynamicResource PendingPlaceholderIconBrush}" HorizontalAlignment="Center"/>
                                                        <TextBlock FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource PendingPlaceholderTextBrush}"
                                                                   Text="{Binding PendingStatusText}"
                                                                   TextAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <controls:ViewportLazyImage FilePath="{Binding PreviewPath}"
                                                                            Stretch="UniformToFill"
                                                                            HorizontalAlignment="Stretch"
                                                                            VerticalAlignment="Stretch"
                                                                            IsVisible="{Binding HasPreview}"/>
                                                <Border HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Margin="5"
                                                        Background="#99000000"
                                                        CornerRadius="4"
                                                        Padding="4,1">
                                                    <TextBlock FontSize="9" Foreground="White" Text="{Binding KindBadgeText}"/>
                                                </Border>
                                                <Border HorizontalAlignment="Right"
                                                        VerticalAlignment="Bottom"
                                                        Margin="5"
                                                        Background="#B3000000"
                                                        CornerRadius="4"
                                                        Padding="4,1">
                                                    <TextBlock FontSize="9" Foreground="White" Text="{Binding Group.WorkflowBadgeText}"/>
                                                </Border>
                                                <Border Classes="selection-outline" IsVisible="{Binding IsSelected}"/>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="0" Grid.Column="4" Classes="app-card" Margin="0,12,12,10" Padding="10,10">
            <Grid RowDefinitions="Auto,10,*,10,Auto">
                <Button Grid.Row="0"
                        Width="92" Height="76"
                        HorizontalAlignment="Center"
                        CornerRadius="12"
                        Command="{Binding NewWorkspaceCommand}"
                        ToolTip.Tip="新建一张空白画布">
                    <icons:Icon Value="fa-solid fa-plus" FontSize="18"/>
                </Button>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding WorkspaceTabs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="workspace-tab-btn"
                                        Command="{Binding DataContext.SelectWorkspaceTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        PointerPressed="WorkspaceTabButton_PointerPressed"
                                        PointerReleased="WorkspaceTabButton_PointerReleased"
                                        Margin="0,0,0,8"
                                        ToolTip.Tip="{Binding SummaryText}">
                                        <Grid Width="104" Height="104">
                                            <Border HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Width="104"
                                                    Height="104"
                                                    Background="{DynamicResource MediaItemBrush}"
                                                    CornerRadius="14"
                                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <controls:ViewportLazyImage FilePath="{Binding PreviewPath}"
                                                                                Stretch="UniformToFill"
                                                                                HorizontalAlignment="Stretch"
                                                                                VerticalAlignment="Stretch"
                                                                                IsVisible="{Binding HasPreview}"/>

                                                        <Border Background="#122033"
                                                            IsVisible="{Binding HasNoPreview}"/>

                                                    <StackPanel VerticalAlignment="Center"
                                                                HorizontalAlignment="Center"
                                                                Spacing="6"
                                                            IsVisible="{Binding HasNoPreview}">
                                                        <Border Width="34" Height="34" CornerRadius="17" Background="#22000000">
                                                            <Grid>
                                                                <icons:Icon Value="fa-solid fa-film"
                                                                            FontSize="14"
                                                                            Foreground="White"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            IsVisible="{Binding IsVideo}"/>
                                                                <icons:Icon Value="fa-regular fa-image"
                                                                            FontSize="14"
                                                                            Foreground="White"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            IsVisible="{Binding IsImage}"/>
                                                            </Grid>
                                                        </Border>
                                                        <TextBlock FontSize="10"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"
                                                                   Text="{Binding StatusBadgeText}"/>
                                                    </StackPanel>

                                                    <Border Classes="pending-placeholder"
                                                            CornerRadius="14"
                                                            Background="#44111A2B"
                                                            IsVisible="{Binding HasRunningTasks}"/>

                                                    <Border HorizontalAlignment="Left"
                                                            VerticalAlignment="Top"
                                                            Margin="6"
                                                            Background="{Binding KindBadgeBackground}"
                                                            CornerRadius="999"
                                                            Padding="6,2">
                                                        <TextBlock FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"
                                                                   Text="{Binding KindBadgeText}"/>
                                                    </Border>

                                                    <Border HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Margin="6"
                                                            Background="#CC0F172A"
                                                            CornerRadius="999"
                                                            Padding="6,2">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <Ellipse Width="7" Height="7" Fill="{Binding StatusDotBrush}" VerticalAlignment="Center"/>
                                                            <TextBlock FontSize="9"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="White"
                                                                       Text="{Binding StatusBadgeText}"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Width="34"
                                                            Height="34"
                                                            CornerRadius="17"
                                                            Background="#99000000"
                                                            BorderBrush="#D9FFFFFF"
                                                            BorderThickness="1.5"
                                                            IsVisible="{Binding IsVideo}">
                                                        <TextBlock Text="▶"
                                                                   FontSize="16"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Margin="1,0,0,0"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <Border Classes="selection-outline" IsVisible="{Binding IsSelected}" CornerRadius="14"/>
                                        </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel Grid.Row="4" Spacing="8">
                    <Button Padding="8,7"
                            CornerRadius="8"
                            AutomationProperties.Name="在外部打开"
                            Command="{Binding OpenSelectedAssetCommand}">
                        <icons:Icon Value="fa-solid fa-arrow-up-right-from-square" FontSize="13"/>
                    </Button>
                    <Button Padding="8,7"
                            CornerRadius="8"
                            AutomationProperties.Name="在文件管理器中打开"
                            Command="{Binding OpenSelectedAssetInExplorerCommand}">
                        <icons:Icon Value="fa-regular fa-folder-open" FontSize="13"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="3" Classes="app-card" Margin="0,0,12,12" Padding="14,12">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                <Border Grid.Row="0"
                        Classes="sub-card"
                        Padding="10"
                        IsVisible="{Binding WorkspaceSession.HasReferenceImage}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ItemsControl ItemsSource="{Binding WorkspaceSession.ReferenceImagePaths}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="52" Height="52">
                                            <Border CornerRadius="8"
                                                    Background="{DynamicResource MediaItemBrush}"
                                                    BorderBrush="{DynamicResource ThumbnailBorderBrush}"
                                                    BorderThickness="1"
                                                    Cursor="Hand"
                                                    PointerPressed="ReferenceImageThumbnail_PointerPressed">
                                                <controls:ViewportLazyImage FilePath="{Binding .}"
                                                                            Stretch="UniformToFill"
                                                                            HorizontalAlignment="Stretch"
                                                                            VerticalAlignment="Stretch"/>
                                            </Border>
                                            <Button Width="18"
                                                    Height="18"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="0,-4,-4,0"
                                                    Padding="0"
                                                    CornerRadius="9"
                                                    Command="{Binding DataContext.WorkspaceSession.RemoveReferenceImageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding .}"
                                                    ToolTip.Tip="删除参考图">
                                                <icons:Icon Value="fa-solid fa-xmark" FontSize="10"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Width="52"
                                    Height="52"
                                    Padding="0"
                                    CornerRadius="8"
                                    Click="AttachReferenceImage_Click"
                                    IsVisible="{Binding CanAttachReferenceImages}">
                                <icons:Icon Value="fa-solid fa-plus" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Width="42" Height="42"
                            CornerRadius="10"
                            Click="AttachReferenceImage_Click"
                            IsVisible="{Binding CanAttachReferenceImages}"
                            ToolTip.Tip="添加参考图（支持 Ctrl+V 粘贴）">
                        <icons:Icon Value="fa-regular fa-image" FontSize="15"/>
                    </Button>
                    <TextBox x:Name="PromptTextBox"
                             Grid.Column="1"
                             Text="{Binding DraftPromptText}"
                             Watermark="{Binding PromptWatermark}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="60"
                             MaxHeight="140"
                             Padding="12,10"/>
                    <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Bottom">
                        <Button Classes="pressable"
                                Padding="14,10"
                                CornerRadius="10"
                                Command="{Binding SubmitPromptCommand}"
                                AutomationProperties.Name="开始创作"
                                Background="{DynamicResource AccentBlueBrush}"
                                Foreground="White">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <icons:Icon Value="fa-solid fa-arrow-up" FontSize="12"/>
                                <TextBlock FontWeight="SemiBold" Text="开始"/>
                            </StackPanel>
                        </Button>
                        <Button Padding="12,8"
                                CornerRadius="10"
                                AutomationProperties.Name="刷新结果"
                                Command="{Binding RefreshWorkspaceCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <icons:Icon Value="fa-solid fa-arrows-rotate" FontSize="12"/>
                                <TextBlock Text="刷新结果"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2" Spacing="2">
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextSubtleBrush}" Text="{Binding WorkspaceStatusSummary}"/>
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource WarningBrush}"
                               IsVisible="{Binding WorkspaceSession.IsVideoReferenceLimitExceeded}"
                               Text="{Binding WorkspaceSession.VideoReferenceLimitHint}"/>
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource WarningBrush}"
                               IsVisible="{Binding WorkspaceSession.IsReferenceImageSizeMismatch}"
                               Text="{Binding WorkspaceSession.ReferenceImageValidationHint}"/>
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource SuccessTextBrush}"
                               IsVisible="{Binding WorkspaceSession.IsReferenceImageSizeMatched}"
                               Text="{Binding WorkspaceSession.ReferenceImageValidationHint}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
