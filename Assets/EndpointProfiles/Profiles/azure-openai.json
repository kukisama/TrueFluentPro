{
  "schemaVersion": 1,
  "id": "builtin.microsoft.azure-openai",
  "vendor": "Microsoft",
  "basePolicyId": "platform.azure-openai",
  "endpointType": "AzureOpenAi",
  "displayName": "Azure OpenAI",
  "subtitle": "官方 Azure OpenAI / Azure AI Foundry OpenAI 资源",
  "glyph": "☁",
  "summary": "默认使用 Azure model-based 路线 (/openai/v1/)，API Key 走 api-key Header；如需 Microsoft Entra ID，可在详情里切换。",
  "defaultNamePrefix": "Azure OpenAI",
  "iconAssetPath": "Assets/EndpointProfiles/Icons/azure-openai.svg",
  "tags": ["builtin", "azure", "aoai"],
  "capabilities": {
    "mode": "InheritDefault",
    "allowed": [],
    "disabled": []
  },
  "overrides": {
    "defaults": {},
    "auth": {
      "defaultMode": "ApiKey",
      "allowedModes": ["ApiKey", "AAD"],
      "defaultApiKeyHeaderMode": "ApiKeyHeader",
      "allowedApiKeyHeaderModes": ["ApiKeyHeader"]
    },
    "capabilities": {
      "mode": "InheritDefault",
      "allowed": [],
      "disabled": []
    },
    "routes": {
      "text": {
        "primaryProtocol": "Responses",
        "primaryUrl": "{baseUrl}/openai/v1/responses",
        "deploymentPrimaryUrl": "{baseUrl}/openai/v1/responses"
      },
      "modelDiscovery": {
        "primaryUrl": ""
      },
      "audio": {
        "primaryUrl": "{baseUrl}/openai/deployments/{deployment}/audio/transcriptions?api-version={apiVersion}",
        "defaultApiVersion": "2025-04-01-preview"
      },
      "speech": {
        "primaryUrl": "{baseUrl}/openai/deployments/{deployment}/audio/speech?api-version={apiVersion}",
        "defaultApiVersion": "2025-04-01-preview"
      },
      "image": {
        "generatePrimaryUrl": "{baseUrl}/openai/v1/images/generations",
        "editPrimaryUrl": "{baseUrl}/openai/v1/images/edits",
        "deploymentGeneratePrimaryUrl": ""
      },
      "video": {
        "defaultMode": "Videos",
        "createPrimaryUrl": "{baseUrl}/openai/v1/videos",
        "jobsCreatePrimaryUrl": "{baseUrl}/openai/v1/video/generations/jobs?api-version=preview",
        "pollPrimaryUrl": "{baseUrl}/openai/v1/videos/{videoId}",
        "jobsPollPrimaryUrl": "{baseUrl}/openai/v1/video/generations/jobs/{videoId}?api-version=preview",
        "downloadPrimaryUrl": "{baseUrl}/openai/v1/videos/{videoId}/content",
        "jobsDownloadPrimaryUrl": "{baseUrl}/openai/v1/video/generations/jobs/{videoId}/content?api-version=preview",
        "downloadVideoContentPrimaryUrl": "{baseUrl}/openai/v1/videos/{videoId}/content/video",
        "generationDownloadPrimaryUrl": "{baseUrl}/openai/v1/video/generations/{videoId}/content",
        "generationDownloadVideoContentPrimaryUrl": "{baseUrl}/openai/v1/video/generations/{videoId}/content/video"
      }
    },
    "version": {
      "endpointApiVersion": "2024-02-01",
      "textApiVersion": "2024-02-01",
      "audioApiVersion": "2025-04-01-preview",
      "speechApiVersion": "2025-04-01-preview",
      "videoApiVersion": ""
    }
  },
  "fallbacks": {
    "modelDiscovery": [],
    "text": ["{baseUrl}/openai/v1/chat/completions", "{baseUrl}/openai/deployments/{deployment}/chat/completions?api-version={apiVersion}"],
    "imageGenerate": [],
    "imageEdit": [],
    "audio": [],
    "speech": [],
    "videoCreate": ["{baseUrl}/openai/v1/videos?api-version=preview"],
    "videoJobsCreate": [],
    "videoPoll": ["{baseUrl}/openai/v1/videos/{videoId}?api-version=preview"],
    "videoJobsPoll": [],
    "videoDownload": ["{baseUrl}/openai/v1/videos/{videoId}/content?api-version=preview"],
    "videoJobsDownload": [],
    "videoDownloadVideoContent": ["{baseUrl}/openai/v1/videos/{videoId}/content/video?api-version=preview"],
    "videoGenerationDownload": [],
    "videoGenerationDownloadVideoContent": []
  },
  "specialPolicies": {
    "allowApimSubscriptionKeyQueryRetry": false,
    "allowPreviewFallback": true
  },
  "defaults": {
    "providerType": "AzureOpenAi",
    "authMode": "ApiKey",
    "apiKeyHeaderMode": "ApiKeyHeader",
    "textApiProtocolMode": "Responses",
    "imageApiRouteMode": "Auto",
    "apiVersion": "2024-02-01",
    "supportsAad": true,
    "clearAzureIdentityFields": false
  },
  "auth": {
    "supportedModes": ["ApiKey", "AAD"],
    "supportedApiKeyHeaderModes": ["ApiKeyHeader"],
    "defaultMode": "ApiKey",
    "defaultApiKeyHeaderMode": "ApiKeyHeader",
    "supportsSubscriptionKeyQueryFallback": false
  },
  "modelDiscovery": {
    "urlCandidates": []
  },
  "text": {
    "preferredProtocol": "Auto",
    "deploymentChatCompletionsUrlCandidates": [
      "{baseUrl}/openai/deployments/{deployment}/chat/completions?api-version={apiVersion}"
    ],
    "responsesUrlCandidates": [],
    "chatCompletionsV1UrlCandidates": [],
    "chatCompletionsRawUrlCandidates": []
  },
  "audio": {
    "defaultApiVersion": "2025-04-01-preview",
    "transcriptionUrlCandidates": [
      "{baseUrl}/openai/deployments/{deployment}/audio/transcriptions?api-version={apiVersion}"
    ]
  },
  "speech": {
    "defaultApiVersion": "2025-04-01-preview",
    "synthesisUrlCandidates": [
      "{baseUrl}/openai/deployments/{deployment}/audio/speech?api-version={apiVersion}"
    ]
  },
  "image": {
    "deploymentGenerateUrlCandidates": [],
    "generateUrlCandidates": [
      "{baseUrl}/openai/v1/images/generations"
    ],
    "editUrlCandidates": [
      "{baseUrl}/openai/v1/images/edits"
    ]
  },
  "video": {
    "apiModeOptions": [
      {
        "mode": "Videos",
        "displayName": "sora2 (/openai/v1/videos)",
        "description": "OpenAI Videos 风格接口，适合当前主流 AOAI 视频模型与更标准的 /videos 路线。"
      },
      {
        "mode": "SoraJobs",
        "displayName": "sora1 (/openai/v1/video/generations/jobs)",
        "description": "AOAI 旧版 Jobs 风格异步接口，创建、轮询与下载路径独立，当前仅 AOAI 资料包保留。"
      }
    ],
    "modelModeBindings": [
      {
        "mode": "Videos",
        "modelPatterns": ["sora-2", "sora-2*"],
        "description": "sora-2 及其变体优先使用 /openai/v1/videos。"
      },
      {
        "mode": "SoraJobs",
        "modelPatterns": ["sora", "sora-1", "sora-1*"],
        "description": "旧版 sora / sora-1 优先使用 jobs 路线。"
      }
    ],
    "supportedApiModes": [
      "Videos",
      "SoraJobs"
    ],
    "createUrlCandidates": [
      "{baseUrl}/openai/v1/videos",
      "{baseUrl}/openai/v1/videos?api-version=preview"
    ],
    "pollUrlCandidates": [
      "{baseUrl}/openai/v1/videos/{videoId}",
      "{baseUrl}/openai/v1/videos/{videoId}?api-version=preview"
    ],
    "downloadUrlCandidates": [
      "{baseUrl}/openai/v1/videos/{videoId}/content",
      "{baseUrl}/openai/v1/videos/{videoId}/content?api-version=preview"
    ],
    "downloadVideoContentUrlCandidates": [
      "{baseUrl}/openai/v1/videos/{videoId}/content/video",
      "{baseUrl}/openai/v1/videos/{videoId}/content/video?api-version=preview"
    ],
    "generationDownloadUrlCandidates": [
      "{baseUrl}/openai/v1/video/generations/{videoId}/content"
    ],
    "generationDownloadVideoContentUrlCandidates": [
      "{baseUrl}/openai/v1/video/generations/{videoId}/content/video"
    ]
  }
}
