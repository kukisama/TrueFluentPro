{
    "id": "builtin.microsoft.apim-gateway",
    "vendor": "Microsoft",
    "endpointType": "ApiManagementGateway",
    "displayName": "APIM 网关",
    "subtitle": "通过 Azure API Management 暴露的 OpenAI 兼容入口",
    "glyph": "⇄",
    "summary": "文本优先 /responses，API Key 优先走 api-key Header，图片优先自动试 deployments、/v1/images 与 /images。",
    "defaultNamePrefix": "APIM 网关",
    "iconAssetPath": "Assets/EndpointProfiles/Icons/apim-gateway.svg",
    "tags": [
        "builtin",
        "azure",
        "apim"
    ],
    "defaults": {
        "providerType": "OpenAiCompatible",
        "authMode": "ApiKey",
        "apiKeyHeaderMode": "ApiKeyHeader",
        "textApiProtocolMode": "Responses",
        "imageApiRouteMode": "Auto",
        "apiVersion": "2025-03-01-preview",
        "supportsAad": false,
        "clearAzureIdentityFields": true
    },
    "auth": {
        "supportedModes": [
            "ApiKey"
        ],
        "supportedApiKeyHeaderModes": [
            "ApiKeyHeader",
            "Bearer"
        ],
        "defaultMode": "ApiKey",
        "defaultApiKeyHeaderMode": "Bearer",
        "supportsSubscriptionKeyQueryFallback": true
    },
    "modelDiscovery": {
        "urlCandidates": [
            "{baseUrl}/models",
            "{baseUrl}/v1/models"
        ]
    },
    "text": {
        "preferredProtocol": "Responses",
        "responsesUrlCandidates": [
            "{baseUrl}/responses?api-version={apiVersion}",
            "{baseUrl}/responses"
        ],
        "chatCompletionsV1UrlCandidates": [
            "{baseUrl}/v1/chat/completions?api-version={apiVersion}",
            "{baseUrl}/v1/chat/completions"
        ],
        "chatCompletionsRawUrlCandidates": [
            "{baseUrl}/chat/completions?api-version={apiVersion}",
            "{baseUrl}/chat/completions"
        ]
    },
        "audio": {
            "defaultApiVersion": "2025-04-01-preview",
            "transcriptionUrlCandidates": [
                "{baseUrl}/openai/deployments/{deployment}/audio/transcriptions?api-version={apiVersion}",
                "{baseUrl}/deployments/{deployment}/audio/transcriptions?api-version={apiVersion}",
                "{baseUrl}/v1/audio/transcriptions?api-version={apiVersion}",
                "{baseUrl}/audio/transcriptions?api-version={apiVersion}",
                "{baseUrl}/v1/audio/transcriptions",
                "{baseUrl}/audio/transcriptions"
            ]
        },
        "speech": {
            "defaultApiVersion": "2025-04-01-preview",
            "synthesisUrlCandidates": [
                "{baseUrl}/openai/deployments/{deployment}/audio/speech?api-version={apiVersion}",
                "{baseUrl}/deployments/{deployment}/audio/speech?api-version={apiVersion}",
                "{baseUrl}/v1/audio/speech?api-version={apiVersion}",
                "{baseUrl}/audio/speech?api-version={apiVersion}",
                "{baseUrl}/v1/audio/speech",
                "{baseUrl}/audio/speech"
            ]
        },
    "image": {
        "deploymentGenerateUrlCandidates": [
            "{baseUrl}/deployments/{deployment}/images/generations?api-version={apiVersion}",
            "{baseUrl}/deployments/{deployment}/images/generations"
        ],
        "generateUrlCandidates": [
            "{baseUrl}/v1/images/generations?api-version={apiVersion}",
            "{baseUrl}/images/generations?api-version={apiVersion}",
            "{baseUrl}/v1/images/generations",
            "{baseUrl}/images/generations"
        ],
        "editUrlCandidates": [
            "{baseUrl}/images/edits?api-version={apiVersion}",
            "{baseUrl}/v1/images/edits?api-version={apiVersion}",
            "{baseUrl}/images/edits",
            "{baseUrl}/v1/images/edits"
        ]
    },
    "video": {
        "apiModeOptions": [
            {
                "mode": "Videos",
                "displayName": "videos (/v1/videos)",
                "description": "通过网关暴露的标准 /v1/videos 路线；是否补 api-version 与具体后缀由资料包候选控制。"
            }
        ],
        "modelModeBindings": [
            {
                "mode": "Videos",
                "modelPatterns": [
                    "sora-2",
                    "sora-2*",
                    "sora",
                    "sora-1",
                    "sora-1*"
                ],
                "description": "当前 APIM 内置资料包只声明 Videos 模式，相关视频模型统一走网关暴露的 /videos 路线。"
            }
        ],
        "supportedApiModes": [
            "Videos"
        ],
        "createUrlCandidates": [
            "{baseUrl}/v1/videos"
        ],
        "pollUrlCandidates": [
            "{baseUrl}/videos/{videoId}",
            "{baseUrl}/v1/videos/{videoId}"
        ],
        "downloadUrlCandidates": [
            "{baseUrl}/videos/{videoId}/content",
            "{baseUrl}/v1/videos/{videoId}/content"
        ],
        "downloadVideoContentUrlCandidates": [
            "{baseUrl}/videos/{videoId}/content/video",
            "{baseUrl}/v1/videos/{videoId}/content/video"
        ]
    }
}