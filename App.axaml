<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:sty="using:FluentAvalonia.Styling"
             x:Class="TrueFluentPro.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- ===== Light 主题 ===== -->
                <ResourceDictionary x:Key="Light">
                    <!-- 表面/背景 -->
                    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#FFF3F5F8"/>
                    <SolidColorBrush x:Key="NavPanelBackgroundBrush" Color="#FFF6F7F9"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFFFF"/>
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE2E8F0"/>
                    <SolidColorBrush x:Key="SubCardBackgroundBrush" Color="#FFF8FAFC"/>
                    <SolidColorBrush x:Key="SubCardBorderBrush" Color="#FFE5E7EB"/>
                    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFF8FAFC"/>
                    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FFF5F5F5"/>
                    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#FFF1F5F9"/>
                    <SolidColorBrush x:Key="ShellNavSelectedBrush" Color="#FFEDF3FC"/>
                    <SolidColorBrush x:Key="SettingsPageBackgroundBrush" Color="#FFF3F5F8"/>
                    <SolidColorBrush x:Key="SettingsNavBackgroundBrush" Color="#FFF6F7F9"/>
                    <SolidColorBrush x:Key="SettingsCardBackgroundBrush" Color="#FFFFFFFF"/>
                    <SolidColorBrush x:Key="SettingsCardBorderBrush" Color="#FFE2E8F0"/>
                    <SolidColorBrush x:Key="SettingsCardInnerBackgroundBrush" Color="#FFF8FAFC"/>
                    <SolidColorBrush x:Key="UserMessageBrush" Color="#FFE3F2FD"/>
                    <SolidColorBrush x:Key="AiMessageBrush" Color="#FFF5F5F5"/>
                    <SolidColorBrush x:Key="CodeBlockBackgroundBrush" Color="#FFF0F0F0"/>
                    <SolidColorBrush x:Key="CodeInlineForegroundBrush" Color="#FFD63384"/>
                    <SolidColorBrush x:Key="TableBorderBrush" Color="#FFE2E8F0"/>
                    <SolidColorBrush x:Key="MediaItemBrush" Color="#FFEEEEEE"/>
                    <SolidColorBrush x:Key="SidebarBrush" Color="#FFFAFAFA"/>

                    <!-- 边框/分隔线 -->
                    <SolidColorBrush x:Key="BorderSubtleBrush" Color="#FFE5E7EB"/>
                    <SolidColorBrush x:Key="BorderMediumBrush" Color="#FFE0E0E0"/>
                    <SolidColorBrush x:Key="BorderStrongBrush" Color="#FFCBD5E1"/>
                    <SolidColorBrush x:Key="DividerBrush" Color="#FFE2E8F0"/>
                    <SolidColorBrush x:Key="InputBorderBrush" Color="#FFE6E6E6"/>
                    <SolidColorBrush x:Key="ThumbnailBorderBrush" Color="#FFCCCCCC"/>

                    <!-- 主色/强调色 -->
                    <SolidColorBrush x:Key="PrimaryBrush" Color="#FF2563EB"/>
                    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#FF1D4ED8"/>
                    <SolidColorBrush x:Key="AccentBlueBrush" Color="#FF1976D2"/>

                    <!-- 文字 -->
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF111827"/>
                    <SolidColorBrush x:Key="TextMutedBrush" Color="#FF666666"/>
                    <SolidColorBrush x:Key="TextSubtleBrush" Color="#FF888888"/>
                    <SolidColorBrush x:Key="TextPlaceholderBrush" Color="#FFAAAAAA"/>
                    <SolidColorBrush x:Key="TimestampBrush" Color="#FF999999"/>
                    <SolidColorBrush x:Key="TextDarkBrush" Color="#FF555555"/>

                    <!-- 状态色 -->
                    <SolidColorBrush x:Key="SuccessBrush" Color="#FF16A34A"/>
                    <SolidColorBrush x:Key="IndicatorGreenBrush" Color="#FF4CAF50"/>
                    <SolidColorBrush x:Key="WarningBrush" Color="#FFE65100"/>
                    <SolidColorBrush x:Key="SuccessTextBrush" Color="#FF2E7D32"/>
                    <SolidColorBrush x:Key="ErrorBrush" Color="#FFB00020"/>

                    <!-- 媒体中心占位符 -->
                    <SolidColorBrush x:Key="PendingPlaceholderBackgroundBrush" Color="#FFF8FBFF"/>
                    <SolidColorBrush x:Key="PendingPlaceholderBorderBrush" Color="#FFD7E6FF"/>
                    <SolidColorBrush x:Key="PendingPlaceholderIconBrush" Color="#FF6C90D8"/>
                    <SolidColorBrush x:Key="PendingPlaceholderTextBrush" Color="#FF4A5D80"/>
                </ResourceDictionary>

                <!-- ===== Dark 主题 ===== -->
                <ResourceDictionary x:Key="Dark">
                    <!-- 表面/背景 -->
                    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#FF151A20"/>
                    <SolidColorBrush x:Key="NavPanelBackgroundBrush" Color="#FF181E25"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF1D242D"/>
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#FF313A45"/>
                    <SolidColorBrush x:Key="SubCardBackgroundBrush" Color="#FF222B35"/>
                    <SolidColorBrush x:Key="SubCardBorderBrush" Color="#FF38424F"/>
                    <SolidColorBrush x:Key="SurfaceBrush" Color="#FF1E1E1E"/>
                    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FF2D2D2D"/>
                    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#FF333333"/>
                    <SolidColorBrush x:Key="ShellNavSelectedBrush" Color="#FF1A2744"/>
                    <SolidColorBrush x:Key="SettingsPageBackgroundBrush" Color="#FF151A20"/>
                    <SolidColorBrush x:Key="SettingsNavBackgroundBrush" Color="#FF181E25"/>
                    <SolidColorBrush x:Key="SettingsCardBackgroundBrush" Color="#FF1D242D"/>
                    <SolidColorBrush x:Key="SettingsCardBorderBrush" Color="#FF313A45"/>
                    <SolidColorBrush x:Key="SettingsCardInnerBackgroundBrush" Color="#FF222B35"/>
                    <SolidColorBrush x:Key="UserMessageBrush" Color="#FF1E3A5F"/>
                    <SolidColorBrush x:Key="AiMessageBrush" Color="#FF2D2D2D"/>
                    <SolidColorBrush x:Key="CodeBlockBackgroundBrush" Color="#FF1E1E1E"/>
                    <SolidColorBrush x:Key="CodeInlineForegroundBrush" Color="#FFE06C9A"/>
                    <SolidColorBrush x:Key="TableBorderBrush" Color="#FF3E3E3E"/>
                    <SolidColorBrush x:Key="MediaItemBrush" Color="#FF363636"/>
                    <SolidColorBrush x:Key="SidebarBrush" Color="#FF252525"/>

                    <!-- 边框/分隔线 -->
                    <SolidColorBrush x:Key="BorderSubtleBrush" Color="#FF3E3E3E"/>
                    <SolidColorBrush x:Key="BorderMediumBrush" Color="#FF4A4A4A"/>
                    <SolidColorBrush x:Key="BorderStrongBrush" Color="#FF555555"/>
                    <SolidColorBrush x:Key="DividerBrush" Color="#FF404040"/>
                    <SolidColorBrush x:Key="InputBorderBrush" Color="#FF454545"/>
                    <SolidColorBrush x:Key="ThumbnailBorderBrush" Color="#FF555555"/>

                    <!-- 主色/强调色 -->
                    <SolidColorBrush x:Key="PrimaryBrush" Color="#FF60A5FA"/>
                    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#FF3B82F6"/>
                    <SolidColorBrush x:Key="AccentBlueBrush" Color="#FF42A5F5"/>

                    <!-- 文字 -->
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFE5E7EB"/>
                    <SolidColorBrush x:Key="TextMutedBrush" Color="#FF9CA3AF"/>
                    <SolidColorBrush x:Key="TextSubtleBrush" Color="#FF8B8B8B"/>
                    <SolidColorBrush x:Key="TextPlaceholderBrush" Color="#FF666666"/>
                    <SolidColorBrush x:Key="TimestampBrush" Color="#FF777777"/>
                    <SolidColorBrush x:Key="TextDarkBrush" Color="#FFB0B0B0"/>

                    <!-- 状态色 -->
                    <SolidColorBrush x:Key="SuccessBrush" Color="#FF22C55E"/>
                    <SolidColorBrush x:Key="IndicatorGreenBrush" Color="#FF66BB6A"/>
                    <SolidColorBrush x:Key="WarningBrush" Color="#FFFFAB40"/>
                    <SolidColorBrush x:Key="SuccessTextBrush" Color="#FF4CAF50"/>
                    <SolidColorBrush x:Key="ErrorBrush" Color="#FFEF5350"/>

                    <!-- 媒体中心占位符 -->
                    <SolidColorBrush x:Key="PendingPlaceholderBackgroundBrush" Color="#FF1E2A3A"/>
                    <SolidColorBrush x:Key="PendingPlaceholderBorderBrush" Color="#FF2E4A6A"/>
                    <SolidColorBrush x:Key="PendingPlaceholderIconBrush" Color="#FF7AA0D8"/>
                    <SolidColorBrush x:Key="PendingPlaceholderTextBrush" Color="#FF8AA0C0"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- ===== 圆角 Token ===== -->
            <CornerRadius x:Key="CornerRadiusSm">4</CornerRadius>
            <CornerRadius x:Key="CornerRadiusMd">8</CornerRadius>
            <CornerRadius x:Key="CornerRadiusLg">12</CornerRadius>
            <CornerRadius x:Key="CornerRadiusPill">999</CornerRadius>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <sty:FluentAvaloniaTheme />

        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
        <StyleInclude Source="avares://TrueFluentPro/Styles/AppSurfaces.axaml" />
        <StyleInclude Source="avares://TrueFluentPro/Styles/AppTypography.axaml" />

        <!-- 全局文本选中样式：蓝底白字（类似 CMD 终端） -->
        <Style Selector="TextBox">
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentBlueBrush}"/>
            <Setter Property="SelectionForegroundBrush" Value="White"/>
        </Style>
        <Style Selector="SelectableTextBlock">
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentBlueBrush}"/>
            <Setter Property="SelectionForegroundBrush" Value="White"/>
        </Style>

        <!-- 3.8 微交互动效 -->
        <!-- 按钮悬停/按压动画：仅对有文本内容的较大按钮生效 -->
        <Style Selector="Button.pressable:pointerover">
            <Setter Property="RenderTransform">
                <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
            </Setter>
        </Style>
        <Style Selector="Button.pressable:pressed">
            <Setter Property="RenderTransform">
                <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
            </Setter>
        </Style>
        <Style Selector="Button.pressable">
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- ToggleButton 悬停/按压动画 -->
        <Style Selector="ToggleButton">
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- ListBoxItem 入场动画 -->
        <Style Selector="ListBoxItem">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
    </Application.Styles>
</Application>