# .env.template — Copy to .env and fill in actual values
# Usage: docker compose --env-file .env up -d

# ─── Instance identifier ───
INSTANCE_NAME=tfp-prod

# ─── Ports (change to avoid conflicts with other instances) ───
API_PORT=5000
API_HTTPS_PORT=5001
PG_PORT=5432
REDIS_PORT=6379

# ─── Data directory ───
DATA_DIR=./data/prod

# ─── PostgreSQL (standard/full mode) ───
PG_PASSWORD=<generate-a-strong-password>
DATABASE_URL=Host=tfp-prod-postgres;Port=5432;Database=truefluentpro;Username=tfp;Password=<same-as-above>

# ─── Redis (full mode) ───
REDIS_PASSWORD=<generate-a-strong-password>
REDIS_URL=tfp-prod-redis:6379,password=<same-as-above>

# ─── Azure credentials ───
AOAI_ENDPOINT=https://your-resource.openai.azure.com/
AOAI_KEY=<your-key>
SPEECH_KEY=<your-key>
SPEECH_REGION=eastus
BLOB_CONNECTION_STRING=<your-connection-string>

# ─── Credential encryption master key (for encrypted DB storage) ───
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=<openssl-rand-base64-32>

# ─── AAD configuration ───
AAD_TENANT_ID=<your-tenant-id>
AAD_CLIENT_ID=<your-client-id>
AAD_AUDIENCE=api://truefluentpro

# ─── Environment ───
ASPNETCORE_ENVIRONMENT=Production
