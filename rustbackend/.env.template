# ═══ TrueFluentPro Gateway — Environment Template ═══
# Copy this to .env and fill in your values.

# ─── Server ───
GATEWAY_PORT=8080
LOG_LEVEL=info

# ─── Auth Mode ───
# "local" = username/password with self-signed JWT
# "aad"   = Azure AD JWT verification
GATEWAY_AUTH__MODE=local

# ─── Auth: Local JWT ───
# Set a stable secret for production (base64-encoded 32+ bytes).
# If left empty, a random secret is generated each restart.
GATEWAY_AUTH__LOCAL__JWT_SECRET=
GATEWAY_AUTH__LOCAL__JWT_EXPIRY_HOURS=24
# Set to true to allow self-registration (POST /v1/auth/register)
GATEWAY_AUTH__LOCAL__ALLOW_REGISTRATION=false

# ─── Auth: Azure AD (when mode = "aad") ───
GATEWAY_AUTH__AAD__TENANT_ID=
GATEWAY_AUTH__AAD__CLIENT_ID=
GATEWAY_AUTH__AAD__AUDIENCE=api://truefluentpro

# ─── Database ───
# Leave empty for SQLite (default, stored in GATEWAY_STORAGE__DATA_DIR).
# Set "postgres://gateway:changeme@postgres:5432/truefluentpro" for PostgreSQL.
GATEWAY_DATABASE__URL=

# ─── Cache ───
# "memory" (default) or "redis"
GATEWAY_CACHE__MODE=memory
# Only needed when mode = "redis":
# GATEWAY_CACHE__REDIS_URL=redis://redis:6379

# ─── Billing ───
# Set to true to enable plan-based quota enforcement.
GATEWAY_BILLING__ENABLED=false

# ─── Credential Encryption ───
# AES-256 master key for encrypting provider credentials in DB.
# Generate: openssl rand -base64 32
GATEWAY_CREDENTIALS__MASTER_KEY_BASE64=

# ─── Azure Key Vault (optional) ───
# GATEWAY_CREDENTIALS__KEYVAULT_URL=https://your-vault.vault.azure.net

# ─── PostgreSQL (docker-compose profile: db) ───
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# ─── Redis (docker-compose profile: cache) ───
REDIS_PORT=6379
