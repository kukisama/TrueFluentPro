<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:TrueFluentPro.ViewModels"
        xmlns:models="using:TrueFluentPro.Models"
        xmlns:controls="using:TrueFluentPro.Controls"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:views="using:TrueFluentPro.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="TrueFluentPro.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        Title="译见 Pro"
        MinWidth="1000" MinHeight="550"
        >

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <controls:LevelToHeightConverter x:Key="LevelToHeight" MaxHeight="16"/>
    </Window.Resources>

    <!-- 主体：NavigationView 直接占满窗口 -->
    <ui:NavigationView Name="NavView"
                       IsBackButtonVisible="False"
                       IsPaneOpen="True"
                       IsSettingsVisible="True"
                       PaneDisplayMode="Left"
                       SelectionChanged="NavView_SelectionChanged">

        <ui:NavigationView.MenuItems>
            <ui:NavigationViewItem Content="实时翻译" Tag="live">
                <ui:NavigationViewItem.IconSource>
                    <ui:SymbolIconSource Symbol="Microphone"/>
                </ui:NavigationViewItem.IconSource>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem Content="复盘批处理" Tag="review">
                <ui:NavigationViewItem.IconSource>
                    <ui:SymbolIconSource Symbol="Library"/>
                </ui:NavigationViewItem.IconSource>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem Content="Media Studio" Tag="media">
                <ui:NavigationViewItem.IconSource>
                    <ui:SymbolIconSource Symbol="Image"/>
                </ui:NavigationViewItem.IconSource>
            </ui:NavigationViewItem>
        </ui:NavigationView.MenuItems>

        <ui:NavigationView.Content>
            <Grid RowDefinitions="*,Auto">
                <Panel Grid.Row="0">
                    <views:LiveTranslationView Name="LiveView" IsVisible="True"/>
                    <views:ReviewModeView Name="ReviewView" IsVisible="False"/>
                    <views:MediaStudioView Name="MediaStudioViewPage" IsVisible="False"/>
                    <views:SettingsView Name="SettingsViewPage" IsVisible="False"/>
                </Panel>
                <!-- InfoBar 通知（替代纯文字 StatusMessage） -->
                <ui:InfoBar Grid.Row="1"
                            IsOpen="{Binding IsInfoBarOpen, Mode=TwoWay}"
                            Message="{Binding InfoBarMessage}"
                            Severity="{Binding InfoBarSeverity}"
                            IsClosable="True"/>
            </Grid>
        </ui:NavigationView.Content>
    </ui:NavigationView>
</Window>
